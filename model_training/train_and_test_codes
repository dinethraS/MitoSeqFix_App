class CurriculumDNADataset(Dataset):
    """
    Custom PyTorch Dataset for curriculum-based mtDNA repair training.

    Each sample contains:
        - Damaged DNA sequence (model input)
        - Clean DNA sequence (repair target)
        - Damage type label (diagnosis task)

    The dataset supports:
        • Fixed-length sequence encoding
        • Random window sampling for long sequences
        • Dynamic sparsity injection for curriculum learning
    """

    def __init__(self, csv_path, max_len=1024):
        """
        Initialize dataset from CSV file.

        Args:
            csv_path (str): Path to dataset CSV file.
            max_len (int): Maximum sequence length used by the model.
        """

        # Load dataset
        self.df = pd.read_csv(csv_path)

        # Maximum sequence length after padding/truncation
        self.max_len = max_len

        # DNA base-to-integer encoding scheme
        # N represents unknown / masked bases
        self.base_map = {
            'A': 0,
            'C': 1,
            'G': 2,
            'T': 3,
            'N': 4
        }

        # Create numerical mapping for damage classification labels
        unique_types = sorted(self.df['damage_type'].unique())
        self.label_map = {t: i for i, t in enumerate(unique_types)}

        # Display label mapping for verification
        print(f"Label map: {self.label_map}")

    # ─────────────────────────────────────────────────────────
    # Sequence Encoding
    # ─────────────────────────────────────────────────────────
    def encode(self, seq):
        """
        Convert DNA string into fixed-length integer tensor.

        Steps:
            1. Map bases to integer tokens.
            2. Pad shorter sequences using 'N'.
            3. Truncate sequences exceeding max length.
        """

        enc = [self.base_map.get(b.upper(), 4) for b in seq]

        # Pad sequence if shorter than required length
        if len(enc) < self.max_len:
            enc += [4] * (self.max_len - len(enc))

        # Ensure fixed input length
        return enc[:self.max_len]

    # ─────────────────────────────────────────────────────────
    # Dataset Size
    # ─────────────────────────────────────────────────────────
    def __len__(self):
        """Return total number of samples."""
        return len(self.df)

    # ─────────────────────────────────────────────────────────
    # Sample Retrieval
    # ─────────────────────────────────────────────────────────
    def __getitem__(self, idx):
        """
        Retrieve a single training sample.

        Returns:
            damaged_tensor : Input sequence with degradation
            clean_tensor   : Ground truth repaired sequence
            label_tensor   : Damage classification label
        """

        row = self.df.iloc[idx]

        clean_full   = str(row['clean'])
        damaged_full = str(row['damaged'])
        damage_type  = str(row['damage_type'])

        # -----------------------------------------------------
        # Random Window Sampling
        # -----------------------------------------------------
        # Long sequences are randomly cropped to increase
        # training diversity and reduce positional bias.
        L = len(clean_full)

        if L > self.max_len:
            s = random.randint(0, L - self.max_len)
            clean_str   = clean_full[s:s + self.max_len]
            damaged_str = damaged_full[s:s + self.max_len]
        else:
            clean_str, damaged_str = clean_full, damaged_full

        # Encode sequences as tensors
        c = torch.tensor(self.encode(clean_str),   dtype=torch.long)
        d = torch.tensor(self.encode(damaged_str), dtype=torch.long)

        # -----------------------------------------------------
        # Curriculum Sparsity Injection
        # -----------------------------------------------------
        # During training, additional masking is applied
        # according to the current curriculum difficulty level.
        if CURRENT_SPARSITY_PROB > 0:
            d[torch.rand(self.max_len) < CURRENT_SPARSITY_PROB] = 4

        # Convert damage type into classification label
        label = self.label_map.get(damage_type, 0)

        return d, c, torch.tensor(label, dtype=torch.long)


