def evaluate_across_sparsity(model, sparsity_levels,
                             val_loader, device, steps=100):
    """
    Evaluate a trained model across multiple degradation levels.

    The function measures how model performance changes as the
    proportion of missing/damaged bases increases.

    Parameters
    ----------
    model : torch.nn.Module
        Trained model to evaluate.

    sparsity_levels : list
        List of masking probabilities representing damage severity.

    val_loader : DataLoader
        Validation dataset loader.

    device : torch.device
        CPU or GPU execution device.

    steps : int
        Number of validation batches sampled per evaluation.

    Returns
    -------
    results : list of dict
        Repair and diagnosis accuracy for each sparsity level.
    """

    results = []
    global CURRENT_SPARSITY_PROB

    # Loss configuration identical to training evaluation
    criterion = JointCurriculumLoss(label_smoothing=0.1)

    model.eval()

    # ── Evaluate robustness across degradation levels ────────
    for sp in sparsity_levels:

        # Apply evaluation sparsity globally
        CURRENT_SPARSITY_PROB = sp

        _, val_r, val_d = evaluate(
            model,
            val_loader,
            criterion,
            device,
            steps=steps,
            diag_weight=0.3
        )

        results.append({
            'sparsity': sp,
            'val_repair_acc': val_r,
            'val_diag_acc': val_d,
        })

        print(
            f"  sp={int(sp*100):>3}% | "
            f"repair={val_r*100:.2f}% | "
            f"diag={val_d*100:.2f}%"
        )

    # Reset sparsity after evaluation
    CURRENT_SPARSITY_PROB = 0.0

    return results


