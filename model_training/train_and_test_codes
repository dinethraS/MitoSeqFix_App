    1. Accuracy vs sparsity curve (robustness analysis)
    2. Target sparsity comparison bar chart (headline result)
    """

    # Convert sparsity to percentage scale
    sp = [r['sparsity'] * 100 for r in cur_eval]

    # Extract repair and diagnosis metrics
    cur_rep  = [r['val_repair_acc'] * 100 for r in cur_eval]
    cur_diag = [r['val_diag_acc']   * 100 for r in cur_eval]
    fix_rep  = [r['val_repair_acc'] * 100 for r in fix_eval]
    rnd_rep  = [r['val_repair_acc'] * 100 for r in rnd_eval]

    # Create side-by-side comparison figure
    fig, axes = plt.subplots(1, 2, figsize=(13, 5))
    fig.suptitle("MitoSeqFix — Curriculum vs Ablations", fontsize=14)

    # ── Panel 1: Robustness Curve ───────────────────────────
    # Shows how accuracy degrades as sequence damage increases
    ax = axes[0]

    ax.plot(sp, cur_rep,  'b-o', markersize=6,
            label='Curriculum — repair')

    ax.plot(sp, cur_diag, 'b--o', markersize=6, alpha=0.5,
            label='Curriculum — diag')

    ax.plot(sp, fix_rep,  'r-s', markersize=6,
            label='Fixed sparsity')

    ax.plot(sp, rnd_rep,  'g-^', markersize=6,
            label='Random sparsity')

    ax.set_xlabel("Eval sparsity (%)")
    ax.set_ylabel("Accuracy (%)")
    ax.set_title("Accuracy vs sparsity (post-training)")
    ax.legend(fontsize=9)
    ax.grid(True, alpha=0.3)

    # ── Panel 2: Target Benchmark Comparison ────────────────
    # Presents headline comparison at 60% sparsity
    ax = axes[1]

    target_idx = EVAL_SPARSITIES.index(0.60)

    models = ['Curriculum', 'Fixed', 'Random']

    repairs = [
        cur_rep[target_idx],
        fix_rep[target_idx],
        rnd_rep[target_idx]
    ]

    diags = [
        cur_diag[target_idx],
        [r['val_diag_acc'] * 100 for r in fix_eval][target_idx],
        [r['val_diag_acc'] * 100 for r in rnd_eval][target_idx]
    ]

    x = np.arange(len(models))
    w = 0.35

    # Repair accuracy bars (solid)
    ax.bar(x - w/2, repairs, w,
           label='Repair acc',
           color=['steelblue', 'tomato', 'seagreen'])

    # Diagnosis accuracy bars (semi-transparent)
    ax.bar(x + w/2, diags, w,
           label='Diag acc',
           color=['steelblue', 'tomato', 'seagreen'],
           alpha=0.5)

    ax.set_xticks(x)
    ax.set_xticklabels(models)
    ax.set_ylabel("Accuracy (%)")
    ax.set_title(
        "Accuracy at 60% sparsity (target)\n"
        "solid = repair, faded = diagnosis"
    )

    ax.legend(fontsize=9)
    ax.grid(True, alpha=0.3, axis='y')

    # Annotate numerical values above bars
    for i, (r, d) in enumerate(zip(repairs, diags)):
        ax.text(i - w/2, r + 0.3, f"{r:.1f}%", ha='center', fontsize=8)
        ax.text(i + w/2, d + 0.3, f"{d:.1f}%", ha='center', fontsize=8)

    plt.tight_layout()

    # Save figure for dissertation inclusion
    path = MODEL_SAVE_DIR + "results_plot.png"
    plt.savefig(path, dpi=150, bbox_inches='tight')

    plt.show()
    print(f"Saved: {path}")


# Generate final comparison figure
