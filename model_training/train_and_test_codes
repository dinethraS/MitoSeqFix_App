# Inference phase (no gradient computation)
with torch.no_grad():
    for damaged, clean, labels in val_loader:

        damaged = damaged.to(device)
        clean   = clean.to(device)
        labels  = labels.to(device)

        repair_logits, diag_logits, _ = eval_model(damaged)

        # -------------------------
        # Repair task evaluation
        # -------------------------
        mask = clean != PAD_TOKEN_ID

        repair_preds.extend(
            repair_logits.argmax(-1)[mask].cpu().numpy()
        )
        repair_targets.extend(
            clean[mask].cpu().numpy()
        )

        # -------------------------
        # Diagnosis evaluation
        # -------------------------
        probs = torch.softmax(diag_logits, dim=-1)

        diag_preds.extend(probs.argmax(-1).cpu().numpy())
        diag_targets.extend(labels.cpu().numpy())
        diag_probs_all.extend(probs.cpu().numpy())

# Convert to arrays for sklearn metrics
repair_preds   = np.array(repair_preds)
