# -----------------------------
# Define Biologically Accurate Damage Patterns
# -----------------------------
# Pattern 1: Cytosine deamination (C→T dominant, ancient DNA damage)
def pattern_1_cytosine_deamination(seq, base_prob=0.25, end_boost=1.5, end_len=20):
    """
    Simulates ancient DNA damage:
    - C→T is dominant, especially at the ends of sequences
    """
    damaged = []
    L = len(seq)
    for i, base in enumerate(seq):
        prob = base_prob
        if i < end_len or i > L - end_len:
            prob += end_boost  # Increase probability at sequence ends
        if base == 'C' and random.random() < prob:
            damaged.append('T')
        elif base == 'G' and random.random() < prob * 0.45:
            damaged.append('A')  # Less frequent complementary damage
        else:
            damaged.append(base)
    return ''.join(damaged), "deamination_CtoT"  # Return damaged sequence + label

# Pattern 2: Oxidative damage (G→T, C→A)
def pattern_2_oxidative_damage(seq, prob=0.08):
    """Simulates oxidative stress damage"""
    map_ox = {'G': ['T'], 'C': ['A']}  # Damage map
    damaged = [random.choice(map_ox[base]) if base in map_ox and random.random() < prob
               else base for base in seq]
    return ''.join(damaged), "oxidative"

# Pattern 3: Clustered deletions (replication slippage)
def pattern_3_clustered_deletions(seq, del_prob=0.008, cluster_boost=0.06):
    """Introduce deletions in clusters"""
    damaged, prev_del = [], False
    for base in seq:
        p = del_prob + (cluster_boost if prev_del else 0)  # Increase probability after a deletion
        if random.random() < p:
            prev_del = True
            continue  # Skip base → deletion
        damaged.append(base)
        prev_del = False
    return ''.join(damaged), "deletions"

# Pattern 4: Fragmentation + N gaps
def pattern_4_fragmentation_n(seq, frag_prob=0.015, min_frag=40, max_frag=80, n_prob=0.03):
    """Simulate fragmented DNA and N gaps"""
    fragments, current = [], []
    for base in seq:
        current.append(base)
        if len(current) >= min_frag and random.random() < frag_prob:
            fragments.append(''.join(current))
            current = []
        if len(current) > max_frag:
            fragments.append(''.join(current))
            current = []
    full = ''.join(fragments) if fragments else seq

    # Introduce random Ns
    damaged = ['N' if random.random() < n_prob else b for b in full]
    return ''.join(damaged), "fragmentation_N"

# List of all patterns for easy iteration
PATTERNS = [pattern_1_cytosine_deamination, pattern_2_oxidative_damage,
            pattern_3_clustered_deletions, pattern_4_fragmentation_n]

# -----------------------------
# Generate Train/Val/Test Split CSVs
# -----------------------------
def generate_split_csvs(clean_csv, output_dir):
    os.makedirs(output_dir, exist_ok=True)  # Make output directory if it doesn't exist

    df = pd.read_csv(clean_csv)           # Load clean sequences
    sequences = df['seq'].tolist()        # Convert to list
    print(f"Processing {len(sequences)} clean sequences")

    # 80% train, 6% validation, 14% test
    train_seqs, temp_seqs = train_test_split(sequences, train_size=0.8, random_state=42)
    val_seqs, test_seqs = train_test_split(temp_seqs, train_size=0.06/0.2, random_state=42)

    splits = {'train': train_seqs, 'val': val_seqs, 'test': test_seqs}

    # Apply damage patterns and save each split
    for split_name, seqs in splits.items():
        all_damaged, all_clean, all_types = [], [], []
        for clean in seqs:
            for i, pattern in enumerate(PATTERNS):
                damaged, dtype = pattern(clean)  # Apply damage
                all_damaged.append(damaged)
                all_clean.append(clean)
                all_types.append(f"{dtype}_p{i+1}")  # Label pattern type

        # Create DataFrame for split
        split_df = pd.DataFrame({
            'damaged': all_damaged,
            'clean': all_clean,
            'damage_type': all_types
        })

        csv_path = os.path.join(output_dir, f"{split_name}_dataset.csv")  # Output path
        split_df.to_csv(csv_path, index=False)  # Save CSV
        print(f"{split_name}: {len(seqs)} × 4 = {len(split_df):,} pairs → {csv_path}")

# Run splitter
output_dir = "data/splits"
generate_split_csvs('clean_mtdna_sequences.csv', output_dir)

