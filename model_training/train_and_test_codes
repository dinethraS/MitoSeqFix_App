def train_stage(stage_num, resume_checkpoint=None):
    """
    Executes one curriculum learning stage.

    Each stage trains the model under progressively higher
    sequence sparsity (damage severity).

    Key training design principles:
        • Progressive sparsity curriculum
        • Per-stage optimiser reset
        • Sparsity replay to prevent forgetting
        • Cross-stage knowledge transfer
        • Continuous validation monitoring
    """

    global CURRENT_SPARSITY_PROB

    # ----------------------------------------------------------
    # Stage Configuration
    # ----------------------------------------------------------

    start_ep, end_ep, target_sp = CURRICULUM_STAGES[stage_num - 1]
    num_epochs = end_ep - start_ep + 1
    MAX_STEPS  = STEPS_PER_STAGE[stage_num]

    # Fresh model instance per stage
    model = DualModeMitoModel(
        vocab_size=VOCAB_SIZE,
        embed_dim=EMBED_DIM,
        num_heads=NUM_HEADS,
        num_attn_layers=NUM_ATTN_LAYERS,
        num_damage_classes=NUM_DAMAGE_CLASSES,
    ).to(device)

    optimizer, scheduler = make_optimizer_and_scheduler(
        model, stage_num, num_epochs
    )

    criterion = JointCurriculumLoss(label_smoothing=0.1)

    # ----------------------------------------------------------
    # Training History Tracking
    # ----------------------------------------------------------

    history = {k: [] for k in [
        'epoch', 'stage', 'stage_epoch',
        'loss', 'val_loss',
        'repair_acc', 'val_repair_acc',
        'diag_acc', 'val_diag_acc',
        'sparsity', 'effective_sparsity',
        'diag_weight', 'lr',
    ]}

    resume_epoch = start_ep

    # ----------------------------------------------------------
    # Checkpoint Resume Logic
    # ----------------------------------------------------------

    if resume_checkpoint and os.path.exists(resume_checkpoint):

        print(f"Loading checkpoint: {resume_checkpoint}")
        ckpt = torch.load(resume_checkpoint, map_location=device)

        # Always restore learned weights
        sd = ckpt.get('model_state_dict', ckpt)
        model.load_state_dict(sd, strict=False)

        prev_stage = ckpt.get('history', {}).get('stage', [None])[-1]

        if prev_stage == stage_num:
            # Mid-stage resume → restore full training state
            print(f"Mid-stage resume from epoch {ckpt['epoch'] + 1}")

            optimizer.load_state_dict(
                ckpt['optimizer_state_dict']
            )
            scheduler.load_state_dict(
                ckpt['scheduler_state_dict']
            )

            history      = ckpt['history']
            resume_epoch = ckpt['epoch'] + 1

        else:
            # Cross-stage transfer → weights only
            print(f"Cross-stage transfer: {prev_stage} → {stage_num}")

            peak_lr = STAGE_LR[stage_num]
            warm_lr = peak_lr * 0.3

            for g in optimizer.param_groups:
                g['lr'] = warm_lr

            print(
                f"Warm LR start: {warm_lr:.2e} → "
                f"{peak_lr:.2e} over first epoch"
            )
    else:
        print(f"Stage {stage_num} — starting fresh")

    # ----------------------------------------------------------
    # Curriculum Sparsity Setup
    # ----------------------------------------------------------

    diag_w = STAGE_DW[stage_num]
    CURRENT_SPARSITY_PROB = target_sp

    print(f"\n{'='*60}")
    print(
        f"STAGE {stage_num} | Target sparsity {int(target_sp*100)}% | "
        f"Epochs {start_ep}-{end_ep} | {MAX_STEPS} steps/epoch | "
        f"dw={diag_w} | peak_lr={STAGE_LR[stage_num]:.0e}"
    )
    print(f"{'='*60}\n")

    # ==========================================================
    # Training Loop
    # ==========================================================

    for epoch in range(resume_epoch, end_ep + 1):

        _, _, stage_epoch = get_stage_info(epoch)

        # Smooth sparsity transition inside stage
        effective_sp = get_stage_sparsity(
            stage_idx          = stage_num - 1,
            epoch_within_stage = stage_epoch - 1,
            total_stage_epochs = num_epochs
        )

        prev_sp = (
            CURRICULUM_STAGES[stage_num - 2][2]
            if stage_num > 1 else 0.0
        )

        # ------------------------------------------------------
        # Sparsity Replay Sampling
        # ------------------------------------------------------
        # Randomises sparsity per batch so the model retains
        # competence at lower degradation levels.

        def get_batch_sparsity():

            if effective_sp <= 0:
                return 0.0

            # 20% replay from earlier easier regimes
            if random.random() < 0.20:
                return random.uniform(0.0, prev_sp)

            low = max(0.0, prev_sp - 0.10)
            return random.uniform(low, effective_sp)

        CURRENT_SPARSITY_PROB = effective_sp

        model.train()

        epoch_loss = 0
        r_correct = r_total = 0
        d_correct = d_total = 0

        pbar = tqdm(
            enumerate(train_loader),
            total=MAX_STEPS,
            desc=f"St{stage_num} Ep{stage_epoch}/{num_epochs}"
        )

        # ------------------------------------------------------
        # Batch Training
        # ------------------------------------------------------

        for i, (d, c, labels) in pbar:

            if i >= MAX_STEPS:
                break

            batch_sp = get_batch_sparsity()

            # Apply degradation dynamically
            mask = torch.rand_like(d.float()) < batch_sp
            d = d.clone()
            d[mask] = 4      # unknown base token

            d, c, labels = (
                d.to(device),
                c.to(device),
                labels.to(device)
            )

            optimizer.zero_grad()

            rl, dl, conf_scores_all = model(d)

            # Main joint loss
            loss, r_loss, d_loss = criterion(
                rl, dl, c, labels, diag_w
            )

            # Confidence gate regularisation
            g_loss = gate_entropy_loss(
                conf_scores_all, batch_sp
            )

            loss = loss + g_loss

            if torch.isnan(loss):
                print(f"NaN detected at step {i}")
                break

            loss.backward()

            torch.nn.utils.clip_grad_norm_(
                model.parameters(), 1.0
            )

            optimizer.step()

            epoch_loss += loss.item()

            with torch.no_grad():
                r_correct += (
                    torch.argmax(rl, -1) == c
                ).sum().item()
                r_total += c.numel()

                d_correct += (
                    torch.argmax(dl, 1) == labels
                ).sum().item()
                d_total += labels.size(0)

            pbar.set_postfix({
                'sp': f"{int(batch_sp*100)}%",
                'r':  f"{r_loss.item():.3f}",
                'd':  f"{d_loss.item():.3f}",
                'g':  f"{g_loss.item():.4f}",
            })

        # ------------------------------------------------------
        # Learning Rate Update
        # ------------------------------------------------------

        scheduler.step()
        lr = scheduler.get_last_lr()[0]

        # ------------------------------------------------------
        # Validation Evaluation
        # ------------------------------------------------------

        # Performance at target sparsity
        val_loss, val_r, val_d = evaluate(
            model, val_loader, criterion,
            device, steps=50, diag_weight=diag_w
        )

        # Clean-data evaluation (forgetting monitor)
        saved_sp = CURRENT_SPARSITY_PROB
        CURRENT_SPARSITY_PROB = 0.0

        _, val_r_clean, _ = evaluate(
            model, val_loader, criterion,
            device, steps=30, diag_weight=diag_w
        )

        CURRENT_SPARSITY_PROB = saved_sp

        avg_loss = epoch_loss / MAX_STEPS
        avg_r = r_correct / r_total
        avg_d = d_correct / d_total

        # ------------------------------------------------------
        # History Logging
        # ------------------------------------------------------

        history['epoch'].append(epoch)
        history['stage'].append(stage_num)
        history['stage_epoch'].append(stage_epoch)
        history['loss'].append(avg_loss)
        history['val_loss'].append(val_loss)
        history['repair_acc'].append(avg_r)
        history['val_repair_acc'].append(val_r)
        history['diag_acc'].append(avg_d)
        history['val_diag_acc'].append(val_d)
        history['sparsity'].append(target_sp)
        history['effective_sparsity'].append(effective_sp)
        history['diag_weight'].append(diag_w)
        history['lr'].append(lr)

        print(
            f"Stage {stage_num} | Ep {stage_epoch}/{num_epochs} | "
            f"Sp 0-{int(effective_sp*100)}% | "
            f"Repair {avg_r*100:.2f}% → Val@target {val_r*100:.2f}% "
            f"Val@0% {val_r_clean*100:.2f}% | "
            f"Diag {avg_d*100:.2f}% → {val_d*100:.2f}% | "
            f"Loss {avg_loss:.4f} | LR {lr:.6f}"
        )

        # ------------------------------------------------------
        # Checkpoint Saving
        # ------------------------------------------------------

        ckpt_name = (
            f"{MODEL_SAVE_DIR}v2_stage{stage_num}"
            f"_ep{stage_epoch}of{num_epochs}"
            f"_sp{int(effective_sp*100)}"
            f"_rep{val_r*100:.1f}"
            f"_diag{val_d*100:.1f}.pt"
        )

        save_checkpoint(
            ckpt_name,
            model,
            optimizer,
            scheduler,
            epoch,
            history,
            val_r,
            val_d,
            target_sp
        )

        print(f"Saved: {ckpt_name}\n")

    print(f"Stage {stage_num} complete.")
    return model, history, ckpt_name


