# ==============================================================
# Learnable Confidence Gate
# ==============================================================

class LearnableConfidenceGate(nn.Module):
    """
    Novel input-dependent sparsity mechanism.

    The gate estimates a confidence score for each sequence
    position based on the current feature representation.
    Positions below a learned threshold are suppressed during
    attention computation.

    Unlike fixed sparse transformers (e.g., window or random
    attention patterns), sparsity here is dynamically learned
    from data and recalibrated at every stacked layer.

    Each layer learns an independent suppression behaviour,
    enabling hierarchical refinement of sequence quality.
    """

    def __init__(self, embed_dim: int):
        super().__init__()

        # Small MLP used to predict per-position confidence
        self.gate = nn.Sequential(
            nn.Linear(embed_dim, embed_dim // 4),
            nn.ReLU(),
            nn.Linear(embed_dim // 4, 1),
            nn.Sigmoid()
        )

        # Learnable suppression threshold (initially permissive)
        self.threshold = nn.Parameter(torch.tensor(0.2))

    def forward(self, x: torch.Tensor):
        """
        Returns:
            scores : confidence values per position (B, L, 1)
            mask   : boolean suppression mask for attention
        """

        scores = self.gate(x)

        # Clamp threshold to prevent degenerate behaviour
        thr = self.threshold.clamp(0.05, 0.95)

        mask = (scores < thr).squeeze(-1)
        return scores, mask


# ==============================================================
# Confidence-Gated Attention Layer
# ==============================================================

class ConfidenceGatedAttentionLayer(nn.Module):
    """
    Single hierarchical processing unit.

    Structure:
        LayerNorm → Confidence Gate → Multi-Head Attention
        → Residual Connection → Feedforward Network → Residual

    Pre-normalisation improves optimisation stability under
    high sparsity where many tokens may be masked.
    """

    def __init__(self, embed_dim: int, num_heads: int):
        super().__init__()

        # Pre-normalisation
        self.norm = nn.LayerNorm(embed_dim)

        # Learnable sparsity controller
        self.conf_gate = LearnableConfidenceGate(embed_dim)

        # Self-attention mechanism
        self.attention = nn.MultiheadAttention(
            embed_dim,
            num_heads,
            batch_first=True
        )

        # Position-wise feedforward block
        self.ff = nn.Sequential(
            nn.Linear(embed_dim, embed_dim * 2),
            nn.GELU(),
            nn.Dropout(0.1),
            nn.Linear(embed_dim * 2, embed_dim),
        )

        self.ff_norm = nn.LayerNorm(embed_dim)

    def forward(self, x: torch.Tensor):

        # Normalise representations before gating
        normed = self.norm(x)

        # Obtain confidence scores and suppression mask
        scores, mask = self.conf_gate(normed)

        # Safety mechanism:
        # ensure at least one token remains visible
        all_masked = mask.all(dim=1, keepdim=True)
        mask = mask & ~all_masked

        # Self-attention with gated sparsity
        attn_out, _ = self.attention(
            normed,
            normed,
            normed,
            key_padding_mask=mask
        )

        # Residual updates
        x = x + attn_out
        x = x + self.ff(self.ff_norm(x))

        return x, scores


# ==============================================================
# Dual-Mode Mitochondrial DNA Model
# ==============================================================

class DualModeMitoModel(nn.Module):
    """
    Hybrid CNN–Transformer architecture for degraded mtDNA analysis.

    Pipeline:
        Embedding → Dilated CNN Backbone →
        Stacked Confidence-Gated Attention →
        Dual Prediction Heads

    Tasks:
        1. Repair Head:
           Predict corrected nucleotide at each position.

        2. Diagnosis Head:
           Classify overall damage type of the sequence.

    Hierarchical interpretation of stacked gates:
        Layer 1 → Local base damage detection
        Layer 2 → Regional degradation patterns
        Layer 3 → Global fragment quality estimation
    """

    def __init__(self,
                 vocab_size:         int = VOCAB_SIZE,
                 embed_dim:          int = EMBED_DIM,
                 num_heads:          int = NUM_HEADS,
                 num_attn_layers:    int = NUM_ATTN_LAYERS,
                 num_damage_classes: int = NUM_DAMAGE_CLASSES):

        super().__init__()

        # ------------------------------------------------------
        # Token Embedding
        # ------------------------------------------------------
        self.embedding = nn.Embedding(vocab_size, embed_dim)

        # ------------------------------------------------------
        # Dilated CNN Backbone
        # Captures local damage motifs at multiple receptive
        # field scales before global attention.
        # ------------------------------------------------------
        self.cnn_backbone = nn.Sequential(
            nn.Conv1d(embed_dim, 128, kernel_size=7, padding=3, dilation=1),
            nn.GELU(),
            nn.Conv1d(128, 256, kernel_size=5, padding=4, dilation=2),
            nn.GELU(),
            nn.Conv1d(256, embed_dim, kernel_size=3, padding=4, dilation=4),
            nn.GELU(),
        )

        # ------------------------------------------------------
        # Stacked Confidence-Gated Attention Layers
        # ------------------------------------------------------
        self.gated_layers = nn.ModuleList([
            ConfidenceGatedAttentionLayer(embed_dim, num_heads)
            for _ in range(num_attn_layers)
        ])

        # ------------------------------------------------------
        # Repair Head (Token-Level Prediction)
        # ------------------------------------------------------
        self.repair_head = nn.Linear(embed_dim, vocab_size)

        # ------------------------------------------------------
        # Diagnosis Head (Sequence-Level Classification)
        # ------------------------------------------------------
        self.diag_head = nn.Sequential(
            nn.AdaptiveAvgPool1d(1),
            nn.Flatten(),
            nn.Linear(embed_dim, 128),
            nn.GELU(),
            nn.Dropout(0.1),
            nn.Linear(128, num_damage_classes)
        )

    def forward(self, x: torch.Tensor):
        """
        Returns:
            repair_logits   : (B, L, vocab_size)
            diag_logits     : (B, num_damage_classes)
            conf_scores_all : confidence scores from all gates
        """

        # Embedding
        x = self.embedding(x)

        # CNN expects channel-first format
        x = x.permute(0, 2, 1)
        x = self.cnn_backbone(x)

        # Return to sequence-first representation
        x = x.permute(0, 2, 1)

        # Hierarchical gated attention processing
        conf_scores_all = []
        for layer in self.gated_layers:
            x, scores = layer(x)
            conf_scores_all.append(scores)

        # Repair prediction
        repair_logits = self.repair_head(x)

        # Diagnosis prediction
        diag_input = x.permute(0, 2, 1)
        diag_logits = self.diag_head(diag_input)

        return repair_logits, diag_logits, conf_scores_all


