# ==============================================================
# Joint Curriculum Loss
# ==============================================================

class JointCurriculumLoss(nn.Module):
    """
    Multi-task loss combining repair and diagnosis objectives.

    Components:
        1. Repair Loss:
           Token-level cross-entropy predicting corrected bases.

        2. Diagnosis Loss:
           Sequence-level classification of damage type.

    Label smoothing is applied to improve generalisation and
    reduce overconfidence during early curriculum stages.
    """

    def __init__(self, label_smoothing=0.1):
        super().__init__()

        self.repair_fn = nn.CrossEntropyLoss(
            label_smoothing=label_smoothing
        )
        self.diag_fn = nn.CrossEntropyLoss(
            label_smoothing=label_smoothing
        )

    def forward(self,
                repair_logits,
                diag_logits,
                clean,
                damage_labels,
                diag_weight=0.3):
        """
        Returns:
            total_loss, repair_loss, diagnosis_loss
        """

        # Token-level repair objective
        r = self.repair_fn(
            repair_logits.view(-1, repair_logits.size(-1)),
            clean.view(-1)
        )

        # Sequence-level diagnosis objective
        d = self.diag_fn(diag_logits, damage_labels)

        # Weighted multi-task combination
        return r + diag_weight * d, r, d


# ==============================================================
# Curriculum Stage Utilities
# ==============================================================

def get_stage_info(epoch):
    """
    Determines active curriculum stage based on epoch number.

    Returns:
        stage_index,
        target_sparsity,
        epoch_within_stage
    """
    for i, (start, end, sp) in enumerate(CURRICULUM_STAGES, 1):
        if start <= epoch <= end:
            return i, sp, epoch - start + 1

    # Default to final stage
    return 6, 0.95, (
        CURRICULUM_STAGES[-1][1] -
        CURRICULUM_STAGES[-1][0] + 1
    )


def get_stage_sparsity(stage_idx: int,
                       epoch_within_stage: int,
                       total_stage_epochs: int) -> float:
    """
    Smooth linear transition between curriculum stages.

    Instead of abrupt sparsity jumps, sparsity increases
    gradually across each stage to stabilise optimisation.
    """

    target = CURRICULUM_STAGES[stage_idx][2]
    prev   = CURRICULUM_STAGES[stage_idx - 1][2] if stage_idx > 0 else 0.0

    frac = min(
        epoch_within_stage /
        max(total_stage_epochs - 1, 1),
        1.0
    )

    return prev + (target - prev) * frac


# ==============================================================
# Confidence Gate Regularisation
# ==============================================================

def gate_entropy_loss(conf_scores_all: list,
                      target_sparsity: float) -> torch.Tensor:
    """
    Regularisation applied to all confidence gates.

    Term 1 — Entropy Penalty:
        Encourages decisive gating behaviour (values near 0 or 1)
        rather than uncertain mid-range activations.

    Term 2 — Sparsity Alignment:
        Penalises deviation between actual suppression rate
        and curriculum target sparsity.

    Loss is averaged across stacked layers to maintain scale
    independence from model depth.
    """

    eps = 1e-6
    total_loss = torch.tensor(
        0.0,
        device=conf_scores_all[0].device
    )

    for scores in conf_scores_all:

        s = scores.squeeze(-1)

        # Binary entropy penalty
        entropy = -(
            s * (s + eps).log() +
            (1 - s) * (1 - s + eps).log()
        )
        entropy_loss = entropy.mean()

        # Sparsity alignment penalty
        actual_sparsity = (s < 0.5).float().mean()
        sparsity_loss = (actual_sparsity - target_sparsity).pow(2)

        total_loss += (
            0.01 * entropy_loss +
            0.05 * sparsity_loss
        )

    return total_loss / len(conf_scores_all)


# ==============================================================
# Optimiser & Scheduler
# ==============================================================

def make_optimizer_and_scheduler(model: nn.Module,
                                 stage_num: int,
                                 stage_epochs: int):
    """
    Creates a fresh optimiser for each curriculum stage.

    Strategy:
        • AdamW optimiser for stable transformer training
        • Cosine annealing schedule within each stage
        • Learning rate decays to 5% of peak value
    """

    lr = STAGE_LR[stage_num]

    optimizer = torch.optim.AdamW(
        model.parameters(),
        lr=lr,
        weight_decay=1e-4
    )

    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(
        optimizer,
        T_max=stage_epochs,
        eta_min=lr * 0.05
    )

    return optimizer, scheduler


# ==============================================================
# Auxiliary Curriculum Helpers
# ==============================================================

# Retained for ablation experiments
def get_effective_sparsity(stage_epoch, target, warmup=2):
    """
    Optional warmup sparsity used for ablation comparisons.
    """
    if target == 0.0 or stage_epoch > warmup:
        return target
    return target * (stage_epoch / warmup)


def get_diag_weight(sparsity):
    """
    Dynamically increases diagnosis loss importance
    as sequence degradation becomes more severe.
    """
    return round(0.1 + 0.4 * sparsity, 3)


