def train_no_curriculum(mode="fixed", fixed_sparsity=0.60,
                        total_steps=2500, tag="ablation"):
    """
    Train the DualModeMitoModel without curriculum learning.

    Parameters
    ----------
    mode : str
        Training strategy controlling sparsity behaviour:
            "fixed"  → constant sparsity applied from the first step.
            "random" → sparsity sampled uniformly each batch.

    fixed_sparsity : float
        Sparsity level used when mode="fixed".

    total_steps : int
        Total number of optimization iterations.

    tag : str
        Identifier used when saving checkpoints.

    Returns
    -------
    results : list
        Validation performance recorded at evaluation checkpoints.
    model : torch.nn.Module
        Trained model instance.
    """

    global CURRENT_SPARSITY_PROB

    # ── Model Initialization ─────────────────────────────────
    # Dual-task transformer predicting:
    #   (1) sequence repair
    #   (2) damage diagnosis
    model = DualModeMitoModel(
        vocab_size=VOCAB_SIZE,
        embed_dim=EMBED_DIM,
        num_heads=NUM_HEADS,
        num_attn_layers=NUM_ATTN_LAYERS,
        num_damage_classes=NUM_DAMAGE_CLASSES,
    ).to(device)

    # Optimizer with weight decay for regularization
    optimizer = torch.optim.AdamW(
        model.parameters(),
        lr=5e-4,
        weight_decay=1e-4
    )

    # Cosine annealing learning-rate schedule
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(
        optimizer,
        T_max=total_steps,
        eta_min=5e-4 * 0.05
    )

    # Joint loss combining repair and diagnosis objectives
    criterion = JointCurriculumLoss(label_smoothing=0.1)

    results = []
    step = 0
    model.train()

    # Progress bar for monitoring training progress
    pbar = tqdm(total=total_steps, desc=f"No-curriculum [{mode}]")

    # ─────────────────────────────────────────────────────────
    # Training Loop
    # ─────────────────────────────────────────────────────────
    for d, c, labels in train_loader:

        if step >= total_steps:
            break

        # ── Sparsity Control (Ablation Variable) ──────────────
        # Defines damage severity applied to input sequences
        if mode == "fixed":
            CURRENT_SPARSITY_PROB = fixed_sparsity
        elif mode == "random":
            CURRENT_SPARSITY_PROB = random.uniform(0, 0.95)

        # Move batch to GPU / device
        d, c, labels = d.to(device), c.to(device), labels.to(device)

        optimizer.zero_grad()

        # Forward pass
        rl, dl, conf_scores_all = model(d)

        # Joint repair + diagnosis loss
        loss, r_loss, d_loss = criterion(
            rl, dl, c, labels,
            diag_weight=0.3
        )

        # Gate entropy regularization
        # Encourages adaptive routing behaviour
        g_loss = gate_entropy_loss(conf_scores_all,
                                   CURRENT_SPARSITY_PROB)
        loss = loss + g_loss

        # Safety check against unstable training
        if torch.isnan(loss):
            print(f"NaN at step {step} — recording and stopping")
            break

        # Backpropagation
        loss.backward()

        # Gradient clipping for stability
        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)

        optimizer.step()
        scheduler.step()

        # ─────────────────────────────────────────────────────
        # Periodic Evaluation + Checkpoint Saving
        # ─────────────────────────────────────────────────────
        checkpoints = {2500, 5000, 8000, 11000, 14000, 15000}

        if step in checkpoints:

            # Evaluate robustness across multiple sparsity levels
            for eval_sp in [0.0, 0.20, 0.40, 0.60, 0.80, 0.95]:

                CURRENT_SPARSITY_PROB = eval_sp

                _, val_r, val_d = evaluate(
                    model,
                    val_loader,
                    criterion,
                    device,
                    steps=50,
                    diag_weight=0.3
                )

                results.append({
                    'step': step,
                    'eval_sparsity': eval_sp,
                    'val_repair_acc': val_r,
                    'val_diag_acc': val_d,
                    'mode': mode,
                })

                print(
                    f"[{mode}] step={step} | "
                    f"eval_sp={int(eval_sp*100)}% | "
                    f"repair={val_r*100:.2f}% | "
                    f"diag={val_d*100:.2f}%"
                )

            # Save intermediate checkpoint to Google Drive
            checkpoint_path = (
                f"{SAVE_DIR}/{tag}_{mode}_step{step}.pt"
            )

            torch.save({
                'step': step,
                'model_state_dict': model.state_dict(),
                'optimizer_state_dict': optimizer.state_dict(),
                'results': results
            }, checkpoint_path)

            print(f"Backup saved to Drive: {checkpoint_path}")

            # Resume training mode after evaluation
            model.train()

        pbar.update(1)
        step += 1

    pbar.close()

    # ─────────────────────────────────────────────────────────
    # Final Model Saving
    # ─────────────────────────────────────────────────────────
    final_path = f"{SAVE_DIR}/{tag}_{mode}_FINAL.pt"

    torch.save({
        'model_state_dict': model.state_dict(),
        'results': results,
        'mode': mode
    }, final_path)

    print(f"Final model safely saved to Drive: {final_path}")

    return results, model


