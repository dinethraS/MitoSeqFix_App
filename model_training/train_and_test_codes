# Checkpoint Utilities
# ==============================================================

def save_checkpoint(path, model, optimizer, scheduler,
                    epoch, history, val_r, val_d, sparsity):
    """
    Saves full training state for reproducibility.
    """

    torch.save({
        'epoch':                epoch,
        'model_state_dict':     model.state_dict(),
        'optimizer_state_dict': optimizer.state_dict(),
        'scheduler_state_dict': scheduler.state_dict(),
        'history':              history,
        'val_repair_acc':       val_r,
        'val_diag_acc':         val_d,
        'sparsity':             sparsity,
    }, path)


def load_weights_only(path, model):
    """
    Loads model weights without restoring optimiser state.
    Useful for evaluation or transfer experiments.
    """

    ckpt = torch.load(path, map_location=device)

    sd = ckpt.get('model_state_dict', ckpt)
    model.load_state_dict(sd, strict=False)

    epoch   = ckpt.get('epoch', 0)
    history = ckpt.get('history', {})

    return epoch, history


# ==============================================================
# Evaluation Routine
# ==============================================================

@torch.no_grad()
def evaluate(model,
             loader,
             criterion,
             device,
             steps=50,
             diag_weight=0.3):
    """
    Performs limited validation evaluation.

    Computes:
        • average loss
        • repair accuracy (token level)
        • diagnosis accuracy (sequence level)
    """

    model.eval()

    total_loss = 0
    r_correct = r_total = 0
    d_correct = d_total = 0

    for i, (d, c, labels) in enumerate(loader):

        if i >= steps:
            break

        d, c, labels = (
            d.to(device),
            c.to(device),
            labels.to(device)
        )

        rl, dl, _ = model(d)

        loss, _, _ = criterion(
            rl, dl, c, labels, diag_weight
        )

        total_loss += loss.item()

        r_correct += (torch.argmax(rl, -1) == c).sum().item()
        r_total   += c.numel()

        d_correct += (torch.argmax(dl, 1) == labels).sum().item()
        d_total   += labels.size(0)

    return (
        total_loss / steps,
        r_correct / r_total,
        d_correct / d_total
    )


