 to training evaluation\n","    criterion = JointCurriculumLoss(label_smoothing=0.1)\n","\n","    model.eval()\n","\n","    # ── Evaluate robustness across degradation levels ────────\n","    for sp in sparsity_levels:\n","\n","        # Apply evaluation sparsity globally\n","        CURRENT_SPARSITY_PROB = sp\n","\n","        _, val_r, val_d = evaluate(\n","            model,\n","            val_loader,\n","            criterion,\n","            device,\n","            steps=steps,\n","            diag_weight=0.3\n","        )\n","\n","        results.append({\n","            'sparsity': sp,\n","            'val_repair_acc': val_r,\n","            'val_diag_acc': val_d,\n","        })\n","\n","        print(\n","            f\"  sp={int(sp*100):>3}% | \"\n","            f\"repair={val_r*100:.2f}% | \"\n","            f\"diag={val_d*100:.2f}%\"\n","        )\n","\n","    # Reset sparsity after evaluation\n","    CURRENT_SPARSITY_PROB = 0.0\n","\n","    return results\n","\n","\n","# ─────────────────────────────────────────────────────────────\n","# Evaluate All Experimental Models\n","# ─────────────────────────────────────────────────────────────\n","\n","print(\"Evaluating curriculum model...\")\n","cur_eval = evaluate_across_sparsity(\n","    curriculum_model, EVAL_SPARSITIES, val_loader, device\n",")\n","\n","print(\"\\nEvaluating fixed ablation...\")\n","fix_eval = evaluate_across_sparsity(\n","    fixed_model, EVAL_SPARSITIES, val_loader, device\n",")\n","\n","print(\"\\nEvaluating random ablation...\")\n","rnd_eval = evaluate_across_sparsity(\n","    random_model, EVAL_SPARSITIES, val_loader, device\n",")\n","\n","\n","# ─────────────────────────────────────────────────────────────\n","# Visualization of Experimental Results\n","# ─────────────────────────────────────────────────────────────\n","\n","def plot_results(cur_eval, fix_eval, rnd_eval):\n","    \"\"\"\n","    Generate comparative visualizations for curriculum learning\n","    and ablation experiments.\n","\n","    Two plots are produced:\n","    1. Accuracy vs sparsity curve (robustness analysis)\n","    2. Target sparsity comparison bar chart (headline result)\n","    \"\"\"\n","\n","    # Convert sparsity to percentage scale\n","    sp = [r['sparsity'] * 100 for r in cur_eval]\n","\n","    # Extract repair and diagnosis metrics\n","    cur_rep  = [r['val_repair_acc'] * 100 for r in cur_eval]\n","    cur_diag = [r['val_diag_acc']   * 100 for r in cur_eval]\n","    fix_rep  = [r['val_repair_acc'] * 100 for r in fix_eval]\n","    rnd_rep  = [r['val_repair_acc'] * 100 for r in rnd_eval]\n","\n","    # Create side-by-side comparison figure\n","    fig, axes = plt.subplots(1, 2, figsize=(13, 5))\n","    fig.suptitle(\"MitoSeqFix — Curriculum vs Ablations\", fontsize=14)\n","\n","    # ── Panel 1: Robustness Curve ───────────────────────────\n","    # Shows how accuracy degrades as sequence damage increases\n","    ax = axes[0]\n","\n","    ax.plot(sp, cur_rep,  'b-o', markersize=6,\n","            label='Curriculum — repair')\n","\n","    ax.plot(sp, cur_diag, 'b--o', markersize=6, alpha=0.5,\n","            label='Curriculum — diag')\n","\n","    ax.plot(sp, fix_rep,  'r-s', markersize=6,\n","            label='Fixed sparsity')\n","\n","    ax.plot(sp, rnd_rep,  'g-^', markersize=6,\n","            label='Random sparsity')\n","\n","    ax.set_xlabel(\"Eval sparsity (%)\")\n","    ax.set_ylabel(\"Accuracy (%)\")\n","    ax.set_title(\"Accuracy vs sparsity (post-training)\")\n","    ax.legend(fontsize=9)\n","    ax.grid(True, alpha=0.3)\n","\n","    # ── Panel 2: Target Benchmark Comparison ────────────────\n","    # Presents headline comparison at 60% sparsity\n","    ax = axes[1]\n","\n","    target_idx = EVAL_SPARSITIES.index(0.60)\n","\n","    models = ['Curriculum', 'Fixed', 'Random']\n","\n","    repairs = [\n","        cur_rep[target_idx],\n","        fix_rep[target_idx],\n","        rnd_rep[target_idx]\n","    ]\n","\n","    diags = [\n","        cur_diag[target_idx],\n","        [r['val_diag_acc'] * 100 for r in fix_eval][target_idx],\n","        [r['val_diag_acc'] * 100 for r in rnd_eval][target_idx]\n","    ]\n","\n","    x = np.arange(len(models))\n","    w = 0.35\n","\n","    # Repair accuracy bars (solid)\n","    ax.bar(x - w/2, repairs, w,\n","           label='Repair acc',\n","           color=['steelblue', 'tomato', 'seagreen'])\n","\n","    # Diagnosis accuracy bars (semi-transparent)\n","    ax.bar(x + w/2, diags, w,\n","           label='Diag acc',\n","           color=['steelblue', 'tomato', 'seagreen'],\n","           alpha=0.5)\n","\n","    ax.set_xticks(x)\n","    ax.set_xticklabels(models)\n","    ax.set_ylabel(\"Accuracy (%)\")\n","    ax.set_title(\n","        \"Accuracy at 60% sparsity (target)\\n\"\n","        \"solid = repair, faded = diagnosis\"\n","    )\n","\n","    ax.legend(fontsize=9)\n","    ax.grid(True, alpha=0.3, axis='y')\n","\n","    # Annotate numerical values above bars\n","    for i, (r, d) in enumerate(zip(repairs, diags)):\n","        ax.text(i - w/2, r + 0.3, f\"{r:.1f}%\", ha='center', fontsize=8)\n","        ax.text(i + w/2, d + 0.3, f\"{d:.1f}%\", ha='center', fontsize=8)\n","\n","    plt.tight_layout()\n","\n","    # Save figure for dissertation inclusion\n","    path = MODEL_SAVE_DIR + \"results_plot.png\"\n","    plt.savefig(path, dpi=150, bbox_inches='tight')\n","\n","    plt.show()\n","    print(f\"Saved: {path}\")\n","\n","\n","# Generate final comparison figure\n","plot_results(cur_eval, fix_eval, rnd_eval)"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"AiJMws8k2ggO","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1776150807663,"user_tz":-330,"elapsed":52,"user":{"displayName":"Dinethra Wickramasekera","userId":"18113936245861993981"}},"outputId":"b91adb45-3763-4e6f-f9fc-4056a1f2e195"},"outputs":[{"output_type":"stream","name":"stdout","text":["\n","============================================================