         (\"Fixed sparsity\", fix_eval),\n","                            (\"Random sparsity\",rnd_eval)]:\n","        print(f\"\\n  {label}\")\n","        print(\"─\"*65)\n","        for r in results:\n","            print(\n","                f\"  {'':18}{int(r['sparsity']*100):>3}%{'':8}\"\n","                f\"  {r['val_repair_acc']*100:>6.2f}%{'':5}\"\n","                f\"  {r['val_diag_acc']*100:>6.2f}%\"\n","            )\n","\n","    # Summary: best repair acc per model\n","    print(\"\\n\" + \"=\"*65)\n","    print(\"  BEST REPAIR ACCURACY PER MODEL\")\n","    print(\"─\"*65)\n","    for label, results in [(\"Curriculum\",      cur_eval),\n","                            (\"Fixed sparsity\",  fix_eval),\n","                            (\"Random sparsity\", rnd_eval)]:\n","        best = max(results, key=lambda r: r['val_repair_acc'])\n","        print(f\"  {label:<20} {best['val_repair_acc']*100:.2f}% \"\n","              f\"@ {int(best['sparsity']*100)}% sparsity\")\n","    print(\"=\"*65)\n","\n","\n","print_results_table(cur_eval, fix_eval, rnd_eval)"]},{"cell_type":"code","source":["# ============================================================\n","# MitoSeqFix — TESTING\n","# ============================================================\n","\n","# This module evaluates trained models across:\n","#   • Sparsity robustness (0% → 60%)\n","#   • Ablation baselines\n","#   • Confusion analysis (repair + diagnosis)\n","#   • ROC-AUC performance\n","#   • Cross-checkpoint comparison\n","\n","\n","# ────────────────────────────────────────────────────────────\n","# Setup: Evaluation checkpoints\n","# ────────────────────────────────────────────────────────────\n","\n","from sklearn.metrics import (\n","    confusion_matrix, classification_report,\n","    roc_auc_score, f1_score, precision_score, recall_score,\n","    roc_curve\n",")\n","\n","import seaborn as sns\n","import matplotlib.pyplot as plt\n","import numpy as np\n","import torch\n","\n","# Sparsity levels used for robustness testing\n","EVAL_SPARSITIES = [0.0, 0.20, 0.40, 0.60]\n","\n","\n","# ============================================================\n","# A — Load trained model checkpoint\n","# ============================================================\n","\n","# Multiple experimental checkpoints (curriculum vs ablations)\n","CURRICULUM_PATH = \"/content/drive/MyDrive/MitoSeqFix/cl_models_v2/v2_stage4_consolidation_ep3.pt\"\n","FIXED_PATH      = \"/content/drive/My Drive/MitoSeqFix_Ablations/ablation_fixed_FINAL.pt\"\n","RANDOM_PATH     = \"/content/drive/My Drive/MitoSeqFix_Ablations/ablation_random_FINAL.pt\"\n","\n","CKPT_PATH = CURRICULUM_PATH  # switch for evaluation\n","\n","# Instantiate identical architecture for fair comparison\n","eval_model = DualModeMitoModel(\n","    vocab_size=VOCAB_SIZE,\n","    embed_dim=EMBED_DIM,\n","    num_heads=NUM_HEADS,\n","    num_attn_layers=NUM_ATTN_LAYERS,\n","    num_damage_classes=NUM_DAMAGE_CLASSES,\n",").to(device)\n","\n","# Load model parameters\n","ckpt = torch.load(CKPT_PATH, map_location=device)\n","eval_model.load_state_dict(ckpt['model_state_dict'], strict=False)\n","eval_model.eval()\n","\n","print(f\"Loaded checkpoint: {CKPT_PATH}\")\n","print(f\"  Epoch           : {ckpt.get('epoch', '?')}\")\n","print(f\"  Val Repair Acc  : {ckpt.get('val_repair_acc', 0)*100:.2f}%\")\n","print(f\"  Val Diagnosis   : {ckpt.get('val_diag_acc', 0)*100:.2f}%\")\n","print(f\"  Training Sparsity: {ckpt.get('sparsity', 0)*100:.0f}%\")\n","\n","\n","# ============================================================\n","# B — Full dataset prediction & metric extraction\n","# ============================================================\n","\n","# Vocabulary definitions\n","NUCLEOTIDE_VOCAB = ['A', 'C', 'G', 'T']\n","DAMAGE_CLASSES   = sorted(train_ds.label_map,\n","                          key=train_ds.label_map.get)\n","\n","PAD_TOKEN_ID = 4  # represents unknown nucleotide\n","\n","repair_preds, repair_targets = [], []\n","diag_preds, diag_targets     = [], []\n","diag_probs_all               = []\n","\n","# Inference phase (no gradient computation)\n","with torch.no_grad():\n","    for damaged, clean, labels in val_loader:\n","\n","        damaged = damaged.to(device)\n","        clean   = clean.to(device)\n","        labels  = labels.to(device)\n","\n","        repair_logits, diag_logits, _ = eval_model(damaged)\n","\n","        # -------------------------\n","        # Repair task evaluation\n","        # -------------------------\n","        mask = clean != PAD_TOKEN_ID\n","\n","        repair_preds.extend(\n","            repair_logits.argmax(-1)[mask].cpu().numpy()\n","        )\n","        repair_targets.extend(\n","            clean[mask].cpu().numpy()\n","        )\n","\n","        # -------------------------\n","        # Diagnosis evaluation\n","        # -------------------------\n","        probs = torch.softmax(diag_logits, dim=-1)\n","\n","        diag_preds.extend(probs.argmax(-1).cpu().numpy())\n","        diag_targets.extend(labels.cpu().numpy())\n","        diag_probs_all.extend(probs.cpu().numpy())\n","\n","# Convert to arrays for sklearn metrics\n","repair_preds   = np.array(repair_preds)\n","repair_targets = np.array(repair_targets)\n","diag_preds     = np.array(diag_preds)\n","diag_targets   = np.array(diag_targets)\n","diag_probs_all = np.array(diag_probs_all)\n","\n","\n","# ============================================================\n","# C — Repair performance analysis\n","# ============================================================\n","\n","repair_acc  = (repair_preds == repair_targets).mean() * 100\n","repair_f1   = f1_score(repair_targets, repair_preds, average='macro') * 100\n","\n","repair_prec  = precision_score(repair_targets, repair_preds,\n","                                average=None) * 100\n","repair_rec   = recall_score(repair_targets, repair_preds,\n","                             average=None) * 100\n","\n","print(\"\\n\" + \"=\"*55)\n","print(\"REPAIR PERFORMANCE\")\n","print(\"=\"*55)\n","print(f\"Accuracy : {repair_acc:.2f}%\")\n","print(f\"Macro F1 : {repair_f1:.2f}%\")\n","\n","for i, nuc in enumerate(NUCLEOTIDE_VOCAB):\n","    print(f\"{nuc}  Precision: {repair_prec[i]:.2f}% | Recall: {repair_rec[i]:.2f}%\")\n","\n","\n","# ============================================================\n","# D — Diagnosis performance analysis\n","# ============================================================\n","\n","diag_acc = (diag_preds == diag_targets).mean() * 100\n","diag_f1  = f1_score(diag_targets, diag_preds, average='macro') * 100\n","\n","try:\n","    diag_auc = roc_auc_score(\n","        diag_targets,\n","        diag_probs_all,\n","        multi_class='ovr',\n","        average='macro'\n","    )\n","except Exception:\n","    diag_auc = float('nan')\n","\n","print(\"\\n\" + \"=\"*55)\n","print(\"DIAGNOSIS PERFORMANCE\")\n","print(\"=\"*55)\n","print(f\"Accuracy : {diag_acc:.2f}%\")\n","print(f\"Macro F1 : {diag_f1:.2f}%\")\n","print(f\"AUC-ROC  : {diag_auc:.4f}\")\n","\n","print(classification_report(\n","    diag_targets,\n","    diag_preds,\n","    target_names=DAMAGE_CLASSES\n","))\n","\n","\n","# ============================================================\n","# E — Repair confusion matrix (biological error focus)\n","# ============================================================\n","\n","cm = confusion_matrix(repair_targets, repair_preds)\n","cm_norm = cm.astype(float) / cm.sum(axis=1, keepdims=True)\n","\n","fig, ax = plt.subplots(figsize=(6, 5))\n","sns.heatmap(\n","    cm_norm,\n","    annot=True,\n","    fmt='.2%',\n","    cmap='Blues',\n","    xticklabels=NUCLEOTIDE_VOCAB,\n","    yticklabels=NUCLEOTIDE_VOCAB,\n","    ax=ax\n",")\n","\n","# Highlight biologically meaningful mutation patterns\n","ax.add_patch(plt.Rectangle((3, 2), 1, 1, fill=False,\n","                           edgecolor='red', lw=2.5))    # G→T\n","ax.add_patch(plt.Rectangle((3, 1), 1, 1, fill=False,\n","                           edgecolor='orange', lw=2.5))  # C→T\n","\n","ax.set_title(f\"Repair Confusion Matrix | Sparsity {ckpt.get('sparsity',0)*100:.0f}%\")\n","ax.set_xlabel(\"Predicted Base\")\n","ax.set_ylabel(\"True Base\")\n","\n","plt.tight_layout()\n","plt.savefig(\"repair_confusion.png\", dpi=150)\n","plt.show()\n","\n","\n","# ============================================================\n","# F — Diagnosis confusion matrix\n","# ============================================================\n","\n","cm = confusion_matrix(diag_targets, diag_preds)\n","cm_norm = cm.astype(float) / cm.sum(axis=1, keepdims=True)\n","\n","fig, ax = plt.subplots(figsize=(6, 5))\n","sns.heatmap(\n","    cm_norm,\n","    annot=True,\n","    fmt='.2%',\n","    cmap='Purples',\n","    xticklabels=DAMAGE_CLASSES,\n","    yticklabels=DAMAGE_CLASSES,\n","    ax=ax\n",")\n","\n","ax.set_title(f\"Diagnosis Confusion Matrix | Sparsity {ckpt.get('sparsity',0)*100:.0f}%\")\n","ax.set_xlabel(\"Predicted Class\")\n","ax.set_ylabel(\"True Class\")\n","\n","plt.tight_layout()\n","plt.savefig(\"diagnosis_confusion.png\", dpi=150)\n","plt.show()\n","\n","\n","# ============================================================\n","# G — ROC-AUC curves (class-wise separability)\n","# ============================================================\n","\n","y_bin = label_binarize(\n","    diag_targets,\n","    classes=list(range(len(DAMAGE_CLASSES)))\n",")\n","\n","fig, ax = plt.subplots(figsize=(7, 6))\n","\n","for i, cls in enumerate(DAMAGE_CLASSES):\n","    fpr, tpr, _ = roc_curve(y_bin[:, i], diag_probs_all[:, i])\n","    auc_i = roc_auc_score(y_bin[:, i], diag_probs_all[:, i])\n","\n","    ax.plot(fpr, tpr, label=f\"{cls} (AUC={auc_i:.3f})\")\n","\n","ax.plot([0, 1], [0, 1], 'k--', lw=1)\n","ax.set_title(\"ROC-AUC per Damage Class\")\n","ax.set_xlabel(\"False Positive Rate\")\n","ax.set_ylabel(\"True Positive Rate\")\n","ax.legend()\n","ax.grid(alpha=0.3)\n","\n","plt.tight_layout()\n","plt.savefig(\"auc_curve.png\", dpi=1