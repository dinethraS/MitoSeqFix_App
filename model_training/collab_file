{"cells":[{"cell_type":"code","source":["!pip install biopython scikit-learn\n","\n","import random\n","import pandas as pd\n","import time\n","import os\n","from Bio import Entrez, SeqIO\n","from sklearn.model_selection import train_test_split  # For splitting dataset into train/val/test\n","\n","# -----------------------------\n","# Download Clean mtDNA Sequences\n","# -----------------------------\n","Entrez.email = \"dinethrawickramnasekera@gmail.com\"  #\n","\n","batch_size = 50               # Number of sequences to fetch at a time\n","sequences = []                # List to store downloaded sequences\n","\n","# Search for all complete human mitochondrial genomes in NCBI\n","handle = Entrez.esearch(\n","    db=\"nuccore\",  # Nucleotide database\n","    term=\"Homo sapiens[Organism] AND mitochondrion[Title] AND complete genome\",  # Search query\n","    retmax=65819  # Number of records to retrieve\n",")\n","record = Entrez.read(handle)  # Parse search results\n","ids = record[\"IdList\"]        # List of sequence IDs\n","print(f\"Found {len(ids)} human mtDNA genomes\")  # Print total found\n","\n","# Fetch sequences in batches\n","for start in range(0, len(ids), batch_size):\n","    end = min(start + batch_size, len(ids))  # Compute end of batch\n","    batch_ids = ids[start:end]               # Slice IDs for this batch\n","\n","    # Fetch sequences in FASTA format\n","    fetch = Entrez.efetch(db=\"nuccore\", id=batch_ids, rettype=\"fasta\", retmode=\"text\")\n","\n","    # Parse each sequence and append to the list\n","    for seq_record in SeqIO.parse(fetch, \"fasta\"):\n","        sequences.append(seq_record)\n","    fetch.close()  # Close fetch connection\n","\n","    print(f\"Downloaded {len(sequences)} / {len(ids)}\")  # Progress update\n","    time.sleep(0.5)  # Sleep to avoid overloading NCBI server\n","\n","print(f\"Downloaded {len(sequences)} clean mtDNA sequences\")  # Total downloaded\n","\n","# Save sequences to CSV\n","clean_df = pd.DataFrame({'seq': [str(s.seq).upper() for s in sequences]})  # Convert sequences to uppercase strings\n","clean_df.to_csv('clean_mtdna_sequences.csv', index=False)  # Save CSV\n","print(\"Clean sequences saved!\")  # Confirmation\n","\n","# -----------------------------\n","# Define Biologically Accurate Damage Patterns\n","# -----------------------------\n","# Pattern 1: Cytosine deamination (C→T dominant, ancient DNA damage)\n","def pattern_1_cytosine_deamination(seq, base_prob=0.25, end_boost=1.5, end_len=20):\n","    \"\"\"\n","    Simulates ancient DNA damage:\n","    - C→T is dominant, especially at the ends of sequences\n","    \"\"\"\n","    damaged = []\n","    L = len(seq)\n","    for i, base in enumerate(seq):\n","        prob = base_prob\n","        if i < end_len or i > L - end_len:\n","            prob += end_boost  # Increase probability at sequence ends\n","        if base == 'C' and random.random() < prob:\n","            damaged.append('T')\n","        elif base == 'G' and random.random() < prob * 0.45:\n","            damaged.append('A')  # Less frequent complementary damage\n","        else:\n","            damaged.append(base)\n","    return ''.join(damaged), \"deamination_CtoT\"  # Return damaged sequence + label\n","\n","# Pattern 2: Oxidative damage (G→T, C→A)\n","def pattern_2_oxidative_damage(seq, prob=0.08):\n","    \"\"\"Simulates oxidative stress damage\"\"\"\n","    map_ox = {'G': ['T'], 'C': ['A']}  # Damage map\n","    damaged = [random.choice(map_ox[base]) if base in map_ox and random.random() < prob\n","               else base for base in seq]\n","    return ''.join(damaged), \"oxidative\"\n","\n","# Pattern 3: Clustered deletions (replication slippage)\n","def pattern_3_clustered_deletions(seq, del_prob=0.008, cluster_boost=0.06):\n","    \"\"\"Introduce deletions in clusters\"\"\"\n","    damaged, prev_del = [], False\n","    for base in seq:\n","        p = del_prob + (cluster_boost if prev_del else 0)  # Increase probability after a deletion\n","        if random.random() < p:\n","            prev_del = True\n","            continue  # Skip base → deletion\n","        damaged.append(base)\n","        prev_del = False\n","    return ''.join(damaged), \"deletions\"\n","\n","# Pattern 4: Fragmentation + N gaps\n","def pattern_4_fragmentation_n(seq, frag_prob=0.015, min_frag=40, max_frag=80, n_prob=0.03):\n","    \"\"\"Simulate fragmented DNA and N gaps\"\"\"\n","    fragments, current = [], []\n","    for base in seq:\n","        current.append(base)\n","        if len(current) >= min_frag and random.random() < frag_prob:\n","            fragments.append(''.join(current))\n","            current = []\n","        if len(current) > max_frag:\n","            fragments.append(''.join(current))\n","            current = []\n","    full = ''.join(fragments) if fragments else seq\n","\n","    # Introduce random Ns\n","    damaged = ['N' if random.random() < n_prob else b for b in full]\n","    return ''.join(damaged), \"fragmentation_N\"\n","\n","# List of all patterns for easy iteration\n","PATTERNS = [pattern_1_cytosine_deamination, pattern_2_oxidative_damage,\n","            pattern_3_clustered_deletions, pattern_4_fragmentation_n]\n","\n","# -----------------------------\n","# Generate Train/Val/Test Split CSVs\n","# -----------------------------\n","def generate_split_csvs(clean_csv, output_dir):\n","    os.makedirs(output_dir, exist_ok=True)  # Make output directory if it doesn't exist\n","\n","    df = pd.read_csv(clean_csv)           # Load clean sequences\n","    sequences = df['seq'].tolist()        # Convert to list\n","    print(f\"Processing {len(sequences)} clean sequences\")\n","\n","    # 80% train, 6% validation, 14% test\n","    train_seqs, temp_seqs = train_test_split(sequences, train_size=0.8, random_state=42)\n","    val_seqs, test_seqs = train_test_split(temp_seqs, train_size=0.06/0.2, random_state=42)\n","\n","    splits = {'train': train_seqs, 'val': val_seqs, 'test': test_seqs}\n","\n","    # Apply damage patterns and save each split\n","    for split_name, seqs in splits.items():\n","        all_damaged, all_clean, all_types = [], [], []\n","        for clean in seqs:\n","            for i, pattern in enumerate(PATTERNS):\n","                damaged, dtype = pattern(clean)  # Apply damage\n","                all_damaged.append(damaged)\n","                all_clean.append(clean)\n","                all_types.append(f\"{dtype}_p{i+1}\")  # Label pattern type\n","\n","        # Create DataFrame for split\n","        split_df = pd.DataFrame({\n","            'damaged': all_damaged,\n","            'clean': all_clean,\n","            'damage_type': all_types\n","        })\n","\n","        csv_path = os.path.join(output_dir, f\"{split_name}_dataset.csv\")  # Output path\n","        split_df.to_csv(csv_path, index=False)  # Save CSV\n","        print(f\"{split_name}: {len(seqs)} × 4 = {len(split_df):,} pairs → {csv_path}\")\n","\n","# Run splitter\n","output_dir = \"data/splits\"\n","generate_split_csvs('clean_mtdna_sequences.csv', output_dir)\n","\n","# -----------------------------\n","# Backup to Google Drive (Colab)\n","# -----------------------------\n","from google.colab import drive\n","drive.mount('/drive')  # Mount Google Drive\n","\n","!cp -r data/splits /drive/MyDrive/  # Copy split datasets to Drive\n","print(\"All done! Use data/splits/train_dataset.csv for training\")\n"],"metadata":{"id":"HHNr3ASq5WUp"},"execution_count":null,"outputs":[]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":3958,"status":"ok","timestamp":1776365690979,"user":{"displayName":"Dinethra Wickramasekera","userId":"18113936245861993981"},"user_tz":-330},"id":"-n6dBL2j0VWl","outputId":"d8a1c88d-f19c-4bac-c5c6-2ae9b8c3c2cd"},"outputs":[{"output_type":"stream","name":"stdout","text":["Drive already mounted at /content/drive; to attempt to forcibly remount, call drive.mount(\"/content/drive\", force_remount=True).\n","GPU available: True\n","Device: Tesla T4\n","Connection Successful!\n","Total checkpoints found: 76\n","Latest S2 file: v2_stage2_ep6of6_sp20_rep78.1_diag97.6.pt\n"]}],"source":["# ─────────────────────────────────────────────────────────────\n","# Install & Mount Drive\n","# ─────────────────────────────────────────────────────────────\n","\n","from google.colab import drive\n","drive.mount('/content/drive')\n","\n","import os, torch\n","print(f\"GPU available: {torch.cuda.is_available()}\")\n","print(f\"Device: {torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'CPU'}\")\n","\n","path = \"/content/drive/MyDrive/MitoSeqFix/cl_models_v2/\"\n","if os.path.exists(path):\n","    print(\"Connection Successful!\")\n","    print(f\"Total checkpoints found: {len(os.listdir(path))}\")\n","    files    = os.listdir(path)\n","    s2_files = [f for f in files if \"stage2\" in f]\n","    if s2_files:\n","        print(f\"Latest S2 file: {sorted(s2_files)[-1]}\")\n","    else:\n","        print(\"No Stage 2 checkpoints yet.\")\n","else:\n","    print(\"Path not found.\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":318,"status":"ok","timestamp":1776365713587,"user":{"displayName":"Dinethra Wickramasekera","userId":"18113936245861993981"},"user_tz":-330},"id":"DmGqyYBA0_26","outputId":"c3903068-c4fb-4a30-a13b-4a91b4ab7b2c"},"outputs":[{"output_type":"stream","name":"stdout","text":["Using: cuda\n","Config loaded.\n","Model: EMBED_DIM=256, NUM_ATTN_LAYERS=3\n","Total epochs: 33\n"]}],"source":["# ─────────────────────────────────────────────────────────────\n","# All Imports & Config\n","# ─────────────────────────────────────────────────────────────\n","\n","import os, random, glob\n","import torch\n","import torch.nn as nn\n","import torch.optim as optim\n","import pandas as pd\n","import numpy as np\n","import matplotlib.pyplot as plt\n","from torch.utils.data import DataLoader, Dataset\n","from tqdm import tqdm\n","\n","# ── Paths ──────────────────────────────────────────────────\n","TRAIN_CSV      = \"/content/drive/MyDrive/MitoSeqFix/splits/train_dataset.csv\"\n","VAL_CSV        = \"/content/drive/MyDrive/MitoSeqFix/splits/val_dataset.csv\"\n","MODEL_SAVE_DIR = \"/content/drive/MyDrive/MitoSeqFix/cl_models_v2/\"\n","os.makedirs(MODEL_SAVE_DIR, exist_ok=True)\n","\n","# ── Config ─────────────────────────────────────────────────\n","MAX_LEN            = 1024\n","BATCH_SIZE         = 32\n","EMBED_DIM          = 256\n","NUM_HEADS          = 8\n","NUM_ATTN_LAYERS    = 3     # stacked gated attention layers\n","                           # Layer 1: local base damage\n","                           # Layer 2: regional end-damage patterns\n","                           # Layer 3: global fragment quality\n","NUM_DAMAGE_CLASSES = 4\n","VOCAB_SIZE         = 5\n","device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n","print(f\"Using: {device}\")\n","\n","CURRENT_SPARSITY_PROB = 0.0\n","\n","# ── Curriculum ─────────────────────────────────────────────\n","# Stage 1 (0%):  10 epochs\n","# Stage 2 (20%):  6 epochs\n","# Stage 3 (40%):  7 epochs\n","# Stage 4 (60%): 10 epochs\n","\n","CURRICULUM_STAGES = [\n","    (1,  10, 0.00),\n","    (11, 16, 0.20),\n","    (17, 23, 0.40),\n","    (24, 33, 0.60),\n","]\n","STAGE_START_EPOCHS = {start for start, _, _ in CURRICULUM_STAGES}\n","TOTAL_EPOCHS = 33\n","\n","# Steps per stage — scales with difficulty\n","STEPS_PER_STAGE = {\n","    1: 2500,\n","    2: 2500,\n","    3: 3000,\n","    4: 3000,\n","}\n","\n","# ── Per-stage diagnosis loss weight ───────────────────────\n","# Stage 1: diag hits 100% val quickly — keep gentle.\n","# Stages 2-6: boost hard. Diag anchors repair during sparsity shock.\n","STAGE_DW = {\n","    1: 0.10,\n","    2: 0.35,\n","    3: 0.35,\n","    4: 0.38,\n","}\n","\n","# ── Per-stage peak learning rate ──────────────────────────\n","# Fresh cosine restart each stage, decays to 5% of peak.\n","STAGE_LR = {\n","    1: 5e-4,\n","    2: 3e-4,\n","    3: 2e-4,\n","    4: 8e-5,\n","}\n","\n","print(\"Config loaded.\")\n","print(f\"Model: EMBED_DIM={EMBED_DIM}, NUM_ATTN_LAYERS={NUM_ATTN_LAYERS}\")\n","print(f\"Total epochs: {TOTAL_EPOCHS}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"executionInfo":{"elapsed":158406,"status":"ok","timestamp":1776365879064,"user":{"displayName":"Dinethra Wickramasekera","userId":"18113936245861993981"},"user_tz":-330},"id":"KVhrUm4M1PwA","colab":{"base_uri":"https://localhost:8080/"},"outputId":"99c604a4-547e-4a8b-d5b1-d33d827256b6"},"outputs":[{"output_type":"stream","name":"stdout","text":["Label map: {'deamination_CtoT_p1': 0, 'deletions_p3': 1, 'fragmentation_N_p4': 2, 'oxidative_p2': 3}\n","Label map: {'deamination_CtoT_p1': 0, 'deletions_p3': 1, 'fragmentation_N_p4': 2, 'oxidative_p2': 3}\n","Train: 210,620 | Val: 15,796\n"]}],"source":["# ─────────────────────────────────────────────────────────────\n","# Curriculum Learning DNA Dataset\n","# ─────────────────────────────────────────────────────────────\n","\n","class CurriculumDNADataset(Dataset):\n","    \"\"\"\n","    Custom PyTorch Dataset for curriculum-based mtDNA repair training.\n","\n","    Each sample contains:\n","        - Damaged DNA sequence (model input)\n","        - Clean DNA sequence (repair target)\n","        - Damage type label (diagnosis task)\n","\n","    The dataset supports:\n","        • Fixed-length sequence encoding\n","        • Random window sampling for long sequences\n","        • Dynamic sparsity injection for curriculum learning\n","    \"\"\"\n","\n","    def __init__(self, csv_path, max_len=1024):\n","        \"\"\"\n","        Initialize dataset from CSV file.\n","\n","        Args:\n","            csv_path (str): Path to dataset CSV file.\n","            max_len (int): Maximum sequence length used by the model.\n","        \"\"\"\n","\n","        # Load dataset\n","        self.df = pd.read_csv(csv_path)\n","\n","        # Maximum sequence length after padding/truncation\n","        self.max_len = max_len\n","\n","        # DNA base-to-integer encoding scheme\n","        # N represents unknown / masked bases\n","        self.base_map = {\n","            'A': 0,\n","            'C': 1,\n","            'G': 2,\n","            'T': 3,\n","            'N': 4\n","        }\n","\n","        # Create numerical mapping for damage classification labels\n","        unique_types = sorted(self.df['damage_type'].unique())\n","        self.label_map = {t: i for i, t in enumerate(unique_types)}\n","\n","        # Display label mapping for verification\n","        print(f\"Label map: {self.label_map}\")\n","\n","    # ─────────────────────────────────────────────────────────\n","    # Sequence Encoding\n","    # ─────────────────────────────────────────────────────────\n","    def encode(self, seq):\n","        \"\"\"\n","        Convert DNA string into fixed-length integer tensor.\n","\n","        Steps:\n","            1. Map bases to integer tokens.\n","            2. Pad shorter sequences using 'N'.\n","            3. Truncate sequences exceeding max length.\n","        \"\"\"\n","\n","        enc = [self.base_map.get(b.upper(), 4) for b in seq]\n","\n","        # Pad sequence if shorter than required length\n","        if len(enc) < self.max_len:\n","            enc += [4] * (self.max_len - len(enc))\n","\n","        # Ensure fixed input length\n","        return enc[:self.max_len]\n","\n","    # ─────────────────────────────────────────────────────────\n","    # Dataset Size\n","    # ─────────────────────────────────────────────────────────\n","    def __len__(self):\n","        \"\"\"Return total number of samples.\"\"\"\n","        return len(self.df)\n","\n","    # ─────────────────────────────────────────────────────────\n","    # Sample Retrieval\n","    # ─────────────────────────────────────────────────────────\n","    def __getitem__(self, idx):\n","        \"\"\"\n","        Retrieve a single training sample.\n","\n","        Returns:\n","            damaged_tensor : Input sequence with degradation\n","            clean_tensor   : Ground truth repaired sequence\n","            label_tensor   : Damage classification label\n","        \"\"\"\n","\n","        row = self.df.iloc[idx]\n","\n","        clean_full   = str(row['clean'])\n","        damaged_full = str(row['damaged'])\n","        damage_type  = str(row['damage_type'])\n","\n","        # -----------------------------------------------------\n","        # Random Window Sampling\n","        # -----------------------------------------------------\n","        # Long sequences are randomly cropped to increase\n","        # training diversity and reduce positional bias.\n","        L = len(clean_full)\n","\n","        if L > self.max_len:\n","            s = random.randint(0, L - self.max_len)\n","            clean_str   = clean_full[s:s + self.max_len]\n","            damaged_str = damaged_full[s:s + self.max_len]\n","        else:\n","            clean_str, damaged_str = clean_full, damaged_full\n","\n","        # Encode sequences as tensors\n","        c = torch.tensor(self.encode(clean_str),   dtype=torch.long)\n","        d = torch.tensor(self.encode(damaged_str), dtype=torch.long)\n","\n","        # -----------------------------------------------------\n","        # Curriculum Sparsity Injection\n","        # -----------------------------------------------------\n","        # During training, additional masking is applied\n","        # according to the current curriculum difficulty level.\n","        if CURRENT_SPARSITY_PROB > 0:\n","            d[torch.rand(self.max_len) < CURRENT_SPARSITY_PROB] = 4\n","\n","        # Convert damage type into classification label\n","        label = self.label_map.get(damage_type, 0)\n","\n","        return d, c, torch.tensor(label, dtype=torch.long)\n","\n","\n","# ─────────────────────────────────────────────────────────────\n","# Dataset Initialization\n","# ─────────────────────────────────────────────────────────────\n","\n","# Create training and validation datasets\n","train_ds = CurriculumDNADataset(TRAIN_CSV, MAX_LEN)\n","val_ds   = CurriculumDNADataset(VAL_CSV,   MAX_LEN)\n","\n","# DataLoaders handle batching, shuffling, and parallel loading\n","train_loader = DataLoader(\n","    train_ds,\n","    batch_size=BATCH_SIZE,\n","    shuffle=True,\n","    num_workers=2,\n","    pin_memory=True\n",")\n","\n","val_loader = DataLoader(\n","    val_ds,\n","    batch_size=BATCH_SIZE,\n","    shuffle=False,\n","    num_workers=2,\n","    pin_memory=True\n",")\n","\n","# Display total number of samples in each dataset split\n","print(f\"Train: {len(train_ds):,} | Val: {len(val_ds):,}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":1936,"status":"ok","timestamp":1776365881020,"user":{"displayName":"Dinethra Wickramasekera","userId":"18113936245861993981"},"user_tz":-330},"id":"wZmfG2uI1Z1t","outputId":"349ba401-b4cb-4f74-85da-adf0566f90bf"},"outputs":[{"output_type":"stream","name":"stdout","text":["Model architecture defined.\n","  Stacked layers   : 3\n","  Repair shape     : torch.Size([2, 1024, 5])\n","  Diag shape       : torch.Size([2, 4])\n","  Gate scores/layer: torch.Size([2, 1024, 1])\n","  Total params     : 2,257,295\n"]}],"source":["# ─────────────────────────────────────────────────────────────\n","# Model Architecture\n","# ─────────────────────────────────────────────────────────────\n","\n","\n","# ==============================================================\n","# Learnable Confidence Gate\n","# ==============================================================\n","\n","class LearnableConfidenceGate(nn.Module):\n","    \"\"\"\n","    Novel input-dependent sparsity mechanism.\n","\n","    The gate estimates a confidence score for each sequence\n","    position based on the current feature representation.\n","    Positions below a learned threshold are suppressed during\n","    attention computation.\n","\n","    Unlike fixed sparse transformers (e.g., window or random\n","    attention patterns), sparsity here is dynamically learned\n","    from data and recalibrated at every stacked layer.\n","\n","    Each layer learns an independent suppression behaviour,\n","    enabling hierarchical refinement of sequence quality.\n","    \"\"\"\n","\n","    def __init__(self, embed_dim: int):\n","        super().__init__()\n","\n","        # Small MLP used to predict per-position confidence\n","        self.gate = nn.Sequential(\n","            nn.Linear(embed_dim, embed_dim // 4),\n","            nn.ReLU(),\n","            nn.Linear(embed_dim // 4, 1),\n","            nn.Sigmoid()\n","        )\n","\n","        # Learnable suppression threshold (initially permissive)\n","        self.threshold = nn.Parameter(torch.tensor(0.2))\n","\n","    def forward(self, x: torch.Tensor):\n","        \"\"\"\n","        Returns:\n","            scores : confidence values per position (B, L, 1)\n","            mask   : boolean suppression mask for attention\n","        \"\"\"\n","\n","        scores = self.gate(x)\n","\n","        # Clamp threshold to prevent degenerate behaviour\n","        thr = self.threshold.clamp(0.05, 0.95)\n","\n","        mask = (scores < thr).squeeze(-1)\n","        return scores, mask\n","\n","\n","# ==============================================================\n","# Confidence-Gated Attention Layer\n","# ==============================================================\n","\n","class ConfidenceGatedAttentionLayer(nn.Module):\n","    \"\"\"\n","    Single hierarchical processing unit.\n","\n","    Structure:\n","        LayerNorm → Confidence Gate → Multi-Head Attention\n","        → Residual Connection → Feedforward Network → Residual\n","\n","    Pre-normalisation improves optimisation stability under\n","    high sparsity where many tokens may be masked.\n","    \"\"\"\n","\n","    def __init__(self, embed_dim: int, num_heads: int):\n","        super().__init__()\n","\n","        # Pre-normalisation\n","        self.norm = nn.LayerNorm(embed_dim)\n","\n","        # Learnable sparsity controller\n","        self.conf_gate = LearnableConfidenceGate(embed_dim)\n","\n","        # Self-attention mechanism\n","        self.attention = nn.MultiheadAttention(\n","            embed_dim,\n","            num_heads,\n","            batch_first=True\n","        )\n","\n","        # Position-wise feedforward block\n","        self.ff = nn.Sequential(\n","            nn.Linear(embed_dim, embed_dim * 2),\n","            nn.GELU(),\n","            nn.Dropout(0.1),\n","            nn.Linear(embed_dim * 2, embed_dim),\n","        )\n","\n","        self.ff_norm = nn.LayerNorm(embed_dim)\n","\n","    def forward(self, x: torch.Tensor):\n","\n","        # Normalise representations before gating\n","        normed = self.norm(x)\n","\n","        # Obtain confidence scores and suppression mask\n","        scores, mask = self.conf_gate(normed)\n","\n","        # Safety mechanism:\n","        # ensure at least one token remains visible\n","        all_masked = mask.all(dim=1, keepdim=True)\n","        mask = mask & ~all_masked\n","\n","        # Self-attention with gated sparsity\n","        attn_out, _ = self.attention(\n","            normed,\n","            normed,\n","            normed,\n","            key_padding_mask=mask\n","        )\n","\n","        # Residual updates\n","        x = x + attn_out\n","        x = x + self.ff(self.ff_norm(x))\n","\n","        return x, scores\n","\n","\n","# ==============================================================\n","# Dual-Mode Mitochondrial DNA Model\n","# ==============================================================\n","\n","class DualModeMitoModel(nn.Module):\n","    \"\"\"\n","    Hybrid CNN–Transformer architecture for degraded mtDNA analysis.\n","\n","    Pipeline:\n","        Embedding → Dilated CNN Backbone →\n","        Stacked Confidence-Gated Attention →\n","        Dual Prediction Heads\n","\n","    Tasks:\n","        1. Repair Head:\n","           Predict corrected nucleotide at each position.\n","\n","        2. Diagnosis Head:\n","           Classify overall damage type of the sequence.\n","\n","    Hierarchical interpretation of stacked gates:\n","        Layer 1 → Local base damage detection\n","        Layer 2 → Regional degradation patterns\n","        Layer 3 → Global fragment quality estimation\n","    \"\"\"\n","\n","    def __init__(self,\n","                 vocab_size:         int = VOCAB_SIZE,\n","                 embed_dim:          int = EMBED_DIM,\n","                 num_heads:          int = NUM_HEADS,\n","                 num_attn_layers:    int = NUM_ATTN_LAYERS,\n","                 num_damage_classes: int = NUM_DAMAGE_CLASSES):\n","\n","        super().__init__()\n","\n","        # ------------------------------------------------------\n","        # Token Embedding\n","        # ------------------------------------------------------\n","        self.embedding = nn.Embedding(vocab_size, embed_dim)\n","\n","        # ------------------------------------------------------\n","        # Dilated CNN Backbone\n","        # Captures local damage motifs at multiple receptive\n","        # field scales before global attention.\n","        # ------------------------------------------------------\n","        self.cnn_backbone = nn.Sequential(\n","            nn.Conv1d(embed_dim, 128, kernel_size=7, padding=3, dilation=1),\n","            nn.GELU(),\n","            nn.Conv1d(128, 256, kernel_size=5, padding=4, dilation=2),\n","            nn.GELU(),\n","            nn.Conv1d(256, embed_dim, kernel_size=3, padding=4, dilation=4),\n","            nn.GELU(),\n","        )\n","\n","        # ------------------------------------------------------\n","        # Stacked Confidence-Gated Attention Layers\n","        # ------------------------------------------------------\n","        self.gated_layers = nn.ModuleList([\n","            ConfidenceGatedAttentionLayer(embed_dim, num_heads)\n","            for _ in range(num_attn_layers)\n","        ])\n","\n","        # ------------------------------------------------------\n","        # Repair Head (Token-Level Prediction)\n","        # ------------------------------------------------------\n","        self.repair_head = nn.Linear(embed_dim, vocab_size)\n","\n","        # ------------------------------------------------------\n","        # Diagnosis Head (Sequence-Level Classification)\n","        # ------------------------------------------------------\n","        self.diag_head = nn.Sequential(\n","            nn.AdaptiveAvgPool1d(1),\n","            nn.Flatten(),\n","            nn.Linear(embed_dim, 128),\n","            nn.GELU(),\n","            nn.Dropout(0.1),\n","            nn.Linear(128, num_damage_classes)\n","        )\n","\n","    def forward(self, x: torch.Tensor):\n","        \"\"\"\n","        Returns:\n","            repair_logits   : (B, L, vocab_size)\n","            diag_logits     : (B, num_damage_classes)\n","            conf_scores_all : confidence scores from all gates\n","        \"\"\"\n","\n","        # Embedding\n","        x = self.embedding(x)\n","\n","        # CNN expects channel-first format\n","        x = x.permute(0, 2, 1)\n","        x = self.cnn_backbone(x)\n","\n","        # Return to sequence-first representation\n","        x = x.permute(0, 2, 1)\n","\n","        # Hierarchical gated attention processing\n","        conf_scores_all = []\n","        for layer in self.gated_layers:\n","            x, scores = layer(x)\n","            conf_scores_all.append(scores)\n","\n","        # Repair prediction\n","        repair_logits = self.repair_head(x)\n","\n","        # Diagnosis prediction\n","        diag_input = x.permute(0, 2, 1)\n","        diag_logits = self.diag_head(diag_input)\n","\n","        return repair_logits, diag_logits, conf_scores_all\n","\n","\n","# ==============================================================\n","# Model Sanity Check\n","# ==============================================================\n","\n","# Instantiate model and verify output dimensions\n","_m = DualModeMitoModel()\n","_x = torch.randint(0, VOCAB_SIZE, (2, MAX_LEN))\n","\n","_rl, _dl, _sc = _m(_x)\n","\n","print(\"Model architecture defined.\")\n","print(f\"  Stacked layers   : {NUM_ATTN_LAYERS}\")\n","print(f\"  Repair shape     : {_rl.shape}\")\n","print(f\"  Diag shape       : {_dl.shape}\")\n","print(f\"  Gate scores/layer: {_sc[0].shape}\")\n","print(f\"  Total params     : {sum(p.numel() for p in _m.parameters()):,}\")\n","\n","del _m, _x, _rl, _dl, _sc"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":25,"status":"ok","timestamp":1776365881060,"user":{"displayName":"Dinethra Wickramasekera","userId":"18113936245861993981"},"user_tz":-330},"id":"5kR7KMXa1a-V","outputId":"f307c0e1-52ce-4d99-d05f-75d0b0d49af8"},"outputs":[{"output_type":"stream","name":"stdout","text":["Helpers defined.\n"]}],"source":["# ─────────────────────────────────────────────────────────────\n","# Loss Functions & Training Utilities\n","# ─────────────────────────────────────────────────────────────\n","\n","\n","# ==============================================================\n","# Joint Curriculum Loss\n","# ==============================================================\n","\n","class JointCurriculumLoss(nn.Module):\n","    \"\"\"\n","    Multi-task loss combining repair and diagnosis objectives.\n","\n","    Components:\n","        1. Repair Loss:\n","           Token-level cross-entropy predicting corrected bases.\n","\n","        2. Diagnosis Loss:\n","           Sequence-level classification of damage type.\n","\n","    Label smoothing is applied to improve generalisation and\n","    reduce overconfidence during early curriculum stages.\n","    \"\"\"\n","\n","    def __init__(self, label_smoothing=0.1):\n","        super().__init__()\n","\n","        self.repair_fn = nn.CrossEntropyLoss(\n","            label_smoothing=label_smoothing\n","        )\n","        self.diag_fn = nn.CrossEntropyLoss(\n","            label_smoothing=label_smoothing\n","        )\n","\n","    def forward(self,\n","                repair_logits,\n","                diag_logits,\n","                clean,\n","                damage_labels,\n","                diag_weight=0.3):\n","        \"\"\"\n","        Returns:\n","            total_loss, repair_loss, diagnosis_loss\n","        \"\"\"\n","\n","        # Token-level repair objective\n","        r = self.repair_fn(\n","            repair_logits.view(-1, repair_logits.size(-1)),\n","            clean.view(-1)\n","        )\n","\n","        # Sequence-level diagnosis objective\n","        d = self.diag_fn(diag_logits, damage_labels)\n","\n","        # Weighted multi-task combination\n","        return r + diag_weight * d, r, d\n","\n","\n","# ==============================================================\n","# Curriculum Stage Utilities\n","# ==============================================================\n","\n","def get_stage_info(epoch):\n","    \"\"\"\n","    Determines active curriculum stage based on epoch number.\n","\n","    Returns:\n","        stage_index,\n","        target_sparsity,\n","        epoch_within_stage\n","    \"\"\"\n","    for i, (start, end, sp) in enumerate(CURRICULUM_STAGES, 1):\n","        if start <= epoch <= end:\n","            return i, sp, epoch - start + 1\n","\n","    # Default to final stage\n","    return 6, 0.95, (\n","        CURRICULUM_STAGES[-1][1] -\n","        CURRICULUM_STAGES[-1][0] + 1\n","    )\n","\n","\n","def get_stage_sparsity(stage_idx: int,\n","                       epoch_within_stage: int,\n","                       total_stage_epochs: int) -> float:\n","    \"\"\"\n","    Smooth linear transition between curriculum stages.\n","\n","    Instead of abrupt sparsity jumps, sparsity increases\n","    gradually across each stage to stabilise optimisation.\n","    \"\"\"\n","\n","    target = CURRICULUM_STAGES[stage_idx][2]\n","    prev   = CURRICULUM_STAGES[stage_idx - 1][2] if stage_idx > 0 else 0.0\n","\n","    frac = min(\n","        epoch_within_stage /\n","        max(total_stage_epochs - 1, 1),\n","        1.0\n","    )\n","\n","    return prev + (target - prev) * frac\n","\n","\n","# ==============================================================\n","# Confidence Gate Regularisation\n","# ==============================================================\n","\n","def gate_entropy_loss(conf_scores_all: list,\n","                      target_sparsity: float) -> torch.Tensor:\n","    \"\"\"\n","    Regularisation applied to all confidence gates.\n","\n","    Term 1 — Entropy Penalty:\n","        Encourages decisive gating behaviour (values near 0 or 1)\n","        rather than uncertain mid-range activations.\n","\n","    Term 2 — Sparsity Alignment:\n","        Penalises deviation between actual suppression rate\n","        and curriculum target sparsity.\n","\n","    Loss is averaged across stacked layers to maintain scale\n","    independence from model depth.\n","    \"\"\"\n","\n","    eps = 1e-6\n","    total_loss = torch.tensor(\n","        0.0,\n","        device=conf_scores_all[0].device\n","    )\n","\n","    for scores in conf_scores_all:\n","\n","        s = scores.squeeze(-1)\n","\n","        # Binary entropy penalty\n","        entropy = -(\n","            s * (s + eps).log() +\n","            (1 - s) * (1 - s + eps).log()\n","        )\n","        entropy_loss = entropy.mean()\n","\n","        # Sparsity alignment penalty\n","        actual_sparsity = (s < 0.5).float().mean()\n","        sparsity_loss = (actual_sparsity - target_sparsity).pow(2)\n","\n","        total_loss += (\n","            0.01 * entropy_loss +\n","            0.05 * sparsity_loss\n","        )\n","\n","    return total_loss / len(conf_scores_all)\n","\n","\n","# ==============================================================\n","# Optimiser & Scheduler\n","# ==============================================================\n","\n","def make_optimizer_and_scheduler(model: nn.Module,\n","                                 stage_num: int,\n","                                 stage_epochs: int):\n","    \"\"\"\n","    Creates a fresh optimiser for each curriculum stage.\n","\n","    Strategy:\n","        • AdamW optimiser for stable transformer training\n","        • Cosine annealing schedule within each stage\n","        • Learning rate decays to 5% of peak value\n","    \"\"\"\n","\n","    lr = STAGE_LR[stage_num]\n","\n","    optimizer = torch.optim.AdamW(\n","        model.parameters(),\n","        lr=lr,\n","        weight_decay=1e-4\n","    )\n","\n","    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(\n","        optimizer,\n","        T_max=stage_epochs,\n","        eta_min=lr * 0.05\n","    )\n","\n","    return optimizer, scheduler\n","\n","\n","# ==============================================================\n","# Auxiliary Curriculum Helpers\n","# ==============================================================\n","\n","# Retained for ablation experiments\n","def get_effective_sparsity(stage_epoch, target, warmup=2):\n","    \"\"\"\n","    Optional warmup sparsity used for ablation comparisons.\n","    \"\"\"\n","    if target == 0.0 or stage_epoch > warmup:\n","        return target\n","    return target * (stage_epoch / warmup)\n","\n","\n","def get_diag_weight(sparsity):\n","    \"\"\"\n","    Dynamically increases diagnosis loss importance\n","    as sequence degradation becomes more severe.\n","    \"\"\"\n","    return round(0.1 + 0.4 * sparsity, 3)\n","\n","\n","# ==============================================================\n","# Checkpoint Utilities\n","# ==============================================================\n","\n","def save_checkpoint(path, model, optimizer, scheduler,\n","                    epoch, history, val_r, val_d, sparsity):\n","    \"\"\"\n","    Saves full training state for reproducibility.\n","    \"\"\"\n","\n","    torch.save({\n","        'epoch':                epoch,\n","        'model_state_dict':     model.state_dict(),\n","        'optimizer_state_dict': optimizer.state_dict(),\n","        'scheduler_state_dict': scheduler.state_dict(),\n","        'history':              history,\n","        'val_repair_acc':       val_r,\n","        'val_diag_acc':         val_d,\n","        'sparsity':             sparsity,\n","    }, path)\n","\n","\n","def load_weights_only(path, model):\n","    \"\"\"\n","    Loads model weights without restoring optimiser state.\n","    Useful for evaluation or transfer experiments.\n","    \"\"\"\n","\n","    ckpt = torch.load(path, map_location=device)\n","\n","    sd = ckpt.get('model_state_dict', ckpt)\n","    model.load_state_dict(sd, strict=False)\n","\n","    epoch   = ckpt.get('epoch', 0)\n","    history = ckpt.get('history', {})\n","\n","    return epoch, history\n","\n","\n","# ==============================================================\n","# Evaluation Routine\n","# ==============================================================\n","\n","@torch.no_grad()\n","def evaluate(model,\n","             loader,\n","             criterion,\n","             device,\n","             steps=50,\n","             diag_weight=0.3):\n","    \"\"\"\n","    Performs limited validation evaluation.\n","\n","    Computes:\n","        • average loss\n","        • repair accuracy (token level)\n","        • diagnosis accuracy (sequence level)\n","    \"\"\"\n","\n","    model.eval()\n","\n","    total_loss = 0\n","    r_correct = r_total = 0\n","    d_correct = d_total = 0\n","\n","    for i, (d, c, labels) in enumerate(loader):\n","\n","        if i >= steps:\n","            break\n","\n","        d, c, labels = (\n","            d.to(device),\n","            c.to(device),\n","            labels.to(device)\n","        )\n","\n","        rl, dl, _ = model(d)\n","\n","        loss, _, _ = criterion(\n","            rl, dl, c, labels, diag_weight\n","        )\n","\n","        total_loss += loss.item()\n","\n","        r_correct += (torch.argmax(rl, -1) == c).sum().item()\n","        r_total   += c.numel()\n","\n","        d_correct += (torch.argmax(dl, 1) == labels).sum().item()\n","        d_total   += labels.size(0)\n","\n","    return (\n","        total_loss / steps,\n","        r_correct / r_total,\n","        d_correct / d_total\n","    )\n","\n","\n","print(\"Helpers defined.\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":36,"status":"ok","timestamp":1776365881102,"user":{"displayName":"Dinethra Wickramasekera","userId":"18113936245861993981"},"user_tz":-330},"id":"HlCR8jWi1hv2","outputId":"d835b46c-10e8-4761-d8d2-a279f6680a3e"},"outputs":[{"output_type":"stream","name":"stdout","text":["Training function defined.\n"]}],"source":["# ─────────────────────────────────────────────────────────────\n","#  Curriculum Training Procedure\n","# ─────────────────────────────────────────────────────────────\n","\n","def train_stage(stage_num, resume_checkpoint=None):\n","    \"\"\"\n","    Executes one curriculum learning stage.\n","\n","    Each stage trains the model under progressively higher\n","    sequence sparsity (damage severity).\n","\n","    Key training design principles:\n","        • Progressive sparsity curriculum\n","        • Per-stage optimiser reset\n","        • Sparsity replay to prevent forgetting\n","        • Cross-stage knowledge transfer\n","        • Continuous validation monitoring\n","    \"\"\"\n","\n","    global CURRENT_SPARSITY_PROB\n","\n","    # ----------------------------------------------------------\n","    # Stage Configuration\n","    # ----------------------------------------------------------\n","\n","    start_ep, end_ep, target_sp = CURRICULUM_STAGES[stage_num - 1]\n","    num_epochs = end_ep - start_ep + 1\n","    MAX_STEPS  = STEPS_PER_STAGE[stage_num]\n","\n","    # Fresh model instance per stage\n","    model = DualModeMitoModel(\n","        vocab_size=VOCAB_SIZE,\n","        embed_dim=EMBED_DIM,\n","        num_heads=NUM_HEADS,\n","        num_attn_layers=NUM_ATTN_LAYERS,\n","        num_damage_classes=NUM_DAMAGE_CLASSES,\n","    ).to(device)\n","\n","    optimizer, scheduler = make_optimizer_and_scheduler(\n","        model, stage_num, num_epochs\n","    )\n","\n","    criterion = JointCurriculumLoss(label_smoothing=0.1)\n","\n","    # ----------------------------------------------------------\n","    # Training History Tracking\n","    # ----------------------------------------------------------\n","\n","    history = {k: [] for k in [\n","        'epoch', 'stage', 'stage_epoch',\n","        'loss', 'val_loss',\n","        'repair_acc', 'val_repair_acc',\n","        'diag_acc', 'val_diag_acc',\n","        'sparsity', 'effective_sparsity',\n","        'diag_weight', 'lr',\n","    ]}\n","\n","    resume_epoch = start_ep\n","\n","    # ----------------------------------------------------------\n","    # Checkpoint Resume Logic\n","    # ----------------------------------------------------------\n","\n","    if resume_checkpoint and os.path.exists(resume_checkpoint):\n","\n","        print(f\"Loading checkpoint: {resume_checkpoint}\")\n","        ckpt = torch.load(resume_checkpoint, map_location=device)\n","\n","        # Always restore learned weights\n","        sd = ckpt.get('model_state_dict', ckpt)\n","        model.load_state_dict(sd, strict=False)\n","\n","        prev_stage = ckpt.get('history', {}).get('stage', [None])[-1]\n","\n","        if prev_stage == stage_num:\n","            # Mid-stage resume → restore full training state\n","            print(f\"Mid-stage resume from epoch {ckpt['epoch'] + 1}\")\n","\n","            optimizer.load_state_dict(\n","                ckpt['optimizer_state_dict']\n","            )\n","            scheduler.load_state_dict(\n","                ckpt['scheduler_state_dict']\n","            )\n","\n","            history      = ckpt['history']\n","            resume_epoch = ckpt['epoch'] + 1\n","\n","        else:\n","            # Cross-stage transfer → weights only\n","            print(f\"Cross-stage transfer: {prev_stage} → {stage_num}\")\n","\n","            peak_lr = STAGE_LR[stage_num]\n","            warm_lr = peak_lr * 0.3\n","\n","            for g in optimizer.param_groups:\n","                g['lr'] = warm_lr\n","\n","            print(\n","                f\"Warm LR start: {warm_lr:.2e} → \"\n","                f\"{peak_lr:.2e} over first epoch\"\n","            )\n","    else:\n","        print(f\"Stage {stage_num} — starting fresh\")\n","\n","    # ----------------------------------------------------------\n","    # Curriculum Sparsity Setup\n","    # ----------------------------------------------------------\n","\n","    diag_w = STAGE_DW[stage_num]\n","    CURRENT_SPARSITY_PROB = target_sp\n","\n","    print(f\"\\n{'='*60}\")\n","    print(\n","        f\"STAGE {stage_num} | Target sparsity {int(target_sp*100)}% | \"\n","        f\"Epochs {start_ep}-{end_ep} | {MAX_STEPS} steps/epoch | \"\n","        f\"dw={diag_w} | peak_lr={STAGE_LR[stage_num]:.0e}\"\n","    )\n","    print(f\"{'='*60}\\n\")\n","\n","    # ==========================================================\n","    # Training Loop\n","    # ==========================================================\n","\n","    for epoch in range(resume_epoch, end_ep + 1):\n","\n","        _, _, stage_epoch = get_stage_info(epoch)\n","\n","        # Smooth sparsity transition inside stage\n","        effective_sp = get_stage_sparsity(\n","            stage_idx          = stage_num - 1,\n","            epoch_within_stage = stage_epoch - 1,\n","            total_stage_epochs = num_epochs\n","        )\n","\n","        prev_sp = (\n","            CURRICULUM_STAGES[stage_num - 2][2]\n","            if stage_num > 1 else 0.0\n","        )\n","\n","        # ------------------------------------------------------\n","        # Sparsity Replay Sampling\n","        # ------------------------------------------------------\n","        # Randomises sparsity per batch so the model retains\n","        # competence at lower degradation levels.\n","\n","        def get_batch_sparsity():\n","\n","            if effective_sp <= 0:\n","                return 0.0\n","\n","            # 20% replay from earlier easier regimes\n","            if random.random() < 0.20:\n","                return random.uniform(0.0, prev_sp)\n","\n","            low = max(0.0, prev_sp - 0.10)\n","            return random.uniform(low, effective_sp)\n","\n","        CURRENT_SPARSITY_PROB = effective_sp\n","\n","        model.train()\n","\n","        epoch_loss = 0\n","        r_correct = r_total = 0\n","        d_correct = d_total = 0\n","\n","        pbar = tqdm(\n","            enumerate(train_loader),\n","            total=MAX_STEPS,\n","            desc=f\"St{stage_num} Ep{stage_epoch}/{num_epochs}\"\n","        )\n","\n","        # ------------------------------------------------------\n","        # Batch Training\n","        # ------------------------------------------------------\n","\n","        for i, (d, c, labels) in pbar:\n","\n","            if i >= MAX_STEPS:\n","                break\n","\n","            batch_sp = get_batch_sparsity()\n","\n","            # Apply degradation dynamically\n","            mask = torch.rand_like(d.float()) < batch_sp\n","            d = d.clone()\n","            d[mask] = 4      # unknown base token\n","\n","            d, c, labels = (\n","                d.to(device),\n","                c.to(device),\n","                labels.to(device)\n","            )\n","\n","            optimizer.zero_grad()\n","\n","            rl, dl, conf_scores_all = model(d)\n","\n","            # Main joint loss\n","            loss, r_loss, d_loss = criterion(\n","                rl, dl, c, labels, diag_w\n","            )\n","\n","            # Confidence gate regularisation\n","            g_loss = gate_entropy_loss(\n","                conf_scores_all, batch_sp\n","            )\n","\n","            loss = loss + g_loss\n","\n","            if torch.isnan(loss):\n","                print(f\"NaN detected at step {i}\")\n","                break\n","\n","            loss.backward()\n","\n","            torch.nn.utils.clip_grad_norm_(\n","                model.parameters(), 1.0\n","            )\n","\n","            optimizer.step()\n","\n","            epoch_loss += loss.item()\n","\n","            with torch.no_grad():\n","                r_correct += (\n","                    torch.argmax(rl, -1) == c\n","                ).sum().item()\n","                r_total += c.numel()\n","\n","                d_correct += (\n","                    torch.argmax(dl, 1) == labels\n","                ).sum().item()\n","                d_total += labels.size(0)\n","\n","            pbar.set_postfix({\n","                'sp': f\"{int(batch_sp*100)}%\",\n","                'r':  f\"{r_loss.item():.3f}\",\n","                'd':  f\"{d_loss.item():.3f}\",\n","                'g':  f\"{g_loss.item():.4f}\",\n","            })\n","\n","        # ------------------------------------------------------\n","        # Learning Rate Update\n","        # ------------------------------------------------------\n","\n","        scheduler.step()\n","        lr = scheduler.get_last_lr()[0]\n","\n","        # ------------------------------------------------------\n","        # Validation Evaluation\n","        # ------------------------------------------------------\n","\n","        # Performance at target sparsity\n","        val_loss, val_r, val_d = evaluate(\n","            model, val_loader, criterion,\n