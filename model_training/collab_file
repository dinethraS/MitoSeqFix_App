/MyDrive/MitoSeqFix/cl_models_v2/v2_stage4_ep10of10_sp60_rep54.1_diag72.6.pt\n"]}],"source":["# ─────────────────────────────────────────────────────────────\n","# Stage 4: 60% sparsity (10 epochs)\n","# ─────────────────────────────────────────────────────────────\n","\n","model, history_s4, last_ckpt_s4 = train_stage(\n","    stage_num=4,\n","    resume_checkpoint=\"/content/drive/MyDrive/MitoSeqFix/cl_models_v2/v2_stage3_ep7of7_sp40_rep66.3_diag85.1.pt\",\n",")\n","print(f\"\\nStage 4 done. Checkpoint: {last_ckpt_s4}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"executionInfo":{"elapsed":24,"status":"ok","timestamp":1776056166053,"user":{"displayName":"Dinethra Wickramasekera","userId":"18113936245861993981"},"user_tz":-330},"id":"JRmWTXrB2VLc","colab":{"base_uri":"https://localhost:8080/"},"outputId":"c4e1f4d2-22d0-40c2-a333-bf1aa39f5d62"},"outputs":[{"output_type":"stream","name":"stdout","text":["Models will be saved to: /content/drive/My Drive/MitoSeqFix_Ablations\n"]}],"source":["# ─────────────────────────────────────────────────────────────\n","# Ablation Experiment: Training Without Curriculum Learning\n","# ─────────────────────────────────────────────────────────────\n","\n","# Directory used to store intermediate and final ablation models\n","SAVE_DIR = '/content/drive/My Drive/MitoSeqFix_Ablations'\n","os.makedirs(SAVE_DIR, exist_ok=True)\n","print(f\"Models will be saved to: {SAVE_DIR}\")\n","\n","\n","def train_no_curriculum(mode=\"fixed\", fixed_sparsity=0.60,\n","                        total_steps=2500, tag=\"ablation\"):\n","    \"\"\"\n","    Train the DualModeMitoModel without curriculum learning.\n","\n","    Parameters\n","    ----------\n","    mode : str\n","        Training strategy controlling sparsity behaviour:\n","            \"fixed\"  → constant sparsity applied from the first step.\n","            \"random\" → sparsity sampled uniformly each batch.\n","\n","    fixed_sparsity : float\n","        Sparsity level used when mode=\"fixed\".\n","\n","    total_steps : int\n","        Total number of optimization iterations.\n","\n","    tag : str\n","        Identifier used when saving checkpoints.\n","\n","    Returns\n","    -------\n","    results : list\n","        Validation performance recorded at evaluation checkpoints.\n","    model : torch.nn.Module\n","        Trained model instance.\n","    \"\"\"\n","\n","    global CURRENT_SPARSITY_PROB\n","\n","    # ── Model Initialization ─────────────────────────────────\n","    # Dual-task transformer predicting:\n","    #   (1) sequence repair\n","    #   (2) damage diagnosis\n","    model = DualModeMitoModel(\n","        vocab_size=VOCAB_SIZE,\n","        embed_dim=EMBED_DIM,\n","        num_heads=NUM_HEADS,\n","        num_attn_layers=NUM_ATTN_LAYERS,\n","        num_damage_classes=NUM_DAMAGE_CLASSES,\n","    ).to(device)\n","\n","    # Optimizer with weight decay for regularization\n","    optimizer = torch.optim.AdamW(\n","        model.parameters(),\n","        lr=5e-4,\n","        weight_decay=1e-4\n","    )\n","\n","    # Cosine annealing learning-rate schedule\n","    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(\n","        optimizer,\n","        T_max=total_steps,\n","        eta_min=5e-4 * 0.05\n","    )\n","\n","    # Joint loss combining repair and diagnosis objectives\n","    criterion = JointCurriculumLoss(label_smoothing=0.1)\n","\n","    results = []\n","    step = 0\n","    model.train()\n","\n","    # Progress bar for monitoring training progress\n","    pbar = tqdm(total=total_steps, desc=f\"No-curriculum [{mode}]\")\n","\n","    # ─────────────────────────────────────────────────────────\n","    # Training Loop\n","    # ─────────────────────────────────────────────────────────\n","    for d, c, labels in train_loader:\n","\n","        if step >= total_steps:\n","            break\n","\n","        # ── Sparsity Control (Ablation Variable) ──────────────\n","        # Defines damage severity applied to input sequences\n","        if mode == \"fixed\":\n","            CURRENT_SPARSITY_PROB = fixed_sparsity\n","        elif mode == \"random\":\n","            CURRENT_SPARSITY_PROB = random.uniform(0, 0.95)\n","\n","        # Move batch to GPU / device\n","        d, c, labels = d.to(device), c.to(device), labels.to(device)\n","\n","        optimizer.zero_grad()\n","\n","        # Forward pass\n","        rl, dl, conf_scores_all = model(d)\n","\n","        # Joint repair + diagnosis loss\n","        loss, r_loss, d_loss = criterion(\n","            rl, dl, c, labels,\n","            diag_weight=0.3\n","        )\n","\n","        # Gate entropy regularization\n","        # Encourages adaptive routing behaviour\n","        g_loss = gate_entropy_loss(conf_scores_all,\n","                                   CURRENT_SPARSITY_PROB)\n","        loss = loss + g_loss\n","\n","        # Safety check against unstable training\n","        if torch.isnan(loss):\n","            print(f\"NaN at step {step} — recording and stopping\")\n","            break\n","\n","        # Backpropagation\n","        loss.backward()\n","\n","        # Gradient clipping for stability\n","        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n","\n","        optimizer.step()\n","        scheduler.step()\n","\n","        # ─────────────────────────────────────────────────────\n","        # Periodic Evaluation + Checkpoint Saving\n","        # ─────────────────────────────────────────────────────\n","        checkpoints = {2500, 5000, 8000, 11000, 14000, 15000}\n","\n","        if step in checkpoints:\n","\n","            # Evaluate robustness across multiple sparsity levels\n","            for eval_sp in [0.0, 0.20, 0.40, 0.60, 0.80, 0.95]:\n","\n","                CURRENT_SPARSITY_PROB = eval_sp\n","\n","                _, val_r, val_d = evaluate(\n","                    model,\n","                    val_loader,\n","                    criterion,\n","                    device,\n","                    steps=50,\n","                    diag_weight=0.3\n","                )\n","\n","                results.append({\n","                    'step': step,\n","                    'eval_sparsity': eval_sp,\n","                    'val_repair_acc': val_r,\n","                    'val_diag_acc': val_d,\n","                    'mode': mode,\n","                })\n","\n","                print(\n","                    f\"[{mode}] step={step} | \"\n","                    f\"eval_sp={int(eval_sp*100)}% | \"\n","                    f\"repair={val_r*100:.2f}% | \"\n","                    f\"diag={val_d*100:.2f}%\"\n","                )\n","\n","            # Save intermediate checkpoint to Google Drive\n","            checkpoint_path = (\n","                f\"{SAVE_DIR}/{tag}_{mode}_step{step}.pt\"\n","            )\n","\n","            torch.save({\n","                'step': step,\n","                'model_state_dict': model.state_dict(),\n","                'optimizer_state_dict': optimizer.state_dict(),\n","                'results': results\n","            }, checkpoint_path)\n","\n","            print(f\"Backup saved to Drive: {checkpoint_path}\")\n","\n","            # Resume training mode after evaluation\n","            model.train()\n","\n","        pbar.update(1)\n","        step += 1\n","\n","    pbar.close()\n","\n","    # ─────────────────────────────────────────────────────────\n","    # Final Model Saving\n","    # ─────────────────────────────────────────────────────────\n","    final_path = f\"{SAVE_DIR}/{tag}_{mode}_FINAL.pt\"\n","\n","    torch.save({\n","        'model_state_dict': model.state_dict(),\n","        'results': results,\n","        'mode': mode\n","    }, final_path)\n","\n","    print(f\"Final model safely saved to Drive: {final_path}\")\n","\n","    return results, model"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"wlM1AKJUCmjZ","outputId":"fcba8edb-079a-4d6b-